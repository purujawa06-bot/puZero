<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#ffffff">
    <title><%= title %></title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="PuZero - Platform alat serbaguna bertenaga AI. Download video dari berbagai platform, konversi unit, dan tingkatkan produktivitas Anda dalam satu tempat.">
    <meta name="keywords" content="AI Downloader, Video Downloader, Productivity Tools, PuZero, Puru Zero, Web Tools">
    <meta name="author" content="Puru Zero">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://puzero.vercel.app/">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="Platform alat serbaguna bertenaga AI untuk produktivitas maksimal.">
    <meta property="og:image" content="/favicon.jpg">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 
                        primary: '#6366f1',
                        secondary: '#0f172a',
                        accent: '#f43f5e'
                    },
                    animation: {
                        'blob': 'blob 7s infinite',
                        'spin-slow': 'spin 3s linear infinite',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' },
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- NProgress (Navigation Loader) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>

    <!-- Marked.js for Markdown Parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <!-- Custom Style -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        :root {
            --primary-glow: radial-gradient(rgba(99, 102, 241, 0.15), rgba(99, 102, 241, 0));
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .htmx-indicator { display: none; }
        .htmx-request.htmx-indicator, .htmx-request .htmx-indicator { display: block; }

        /* Global Animations */
        .fade-in { animation: fadeIn 0.4s ease-out; }
        @keyframes fadeIn { 
            from { opacity: 0; transform: translateY(10px); } 
            to { opacity: 1; transform: translateY(0); } 
        }

        .btn-hover-effect {
            position: relative;
            overflow: hidden;
        }
        .btn-hover-effect::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }
        .btn-hover-effect:active::after {
            width: 300%;
            height: 300%;
        }

        /* Custom NProgress */
        #nprogress .bar { background: #22c55e !important; height: 3px !important; }
        #nprogress .peg { box-shadow: 0 0 10px #22c55e, 0 0 5px #22c55e !important; }
    </style>
</head>
<body class="bg-[#f8fafc] text-slate-900 min-h-[100dvh] flex flex-col antialiased selection:bg-primary/20 selection:text-primary pb-safe">

    <%- include('partials/navbar') %>

    <main id="main-content" class="flex-grow flex flex-col">
        <div class="fade-in flex-grow flex flex-col">
            <% if (typeof page !== 'undefined') { %>
                <%- include(page) %>
            <% } else if (typeof body !== 'undefined') { %>
                <%- body %>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>

    <!-- Global Scripts -->
    <script src="/js/index.js" defer></script>

    <script>
        window.PuZeroState = {
            chatHistory: JSON.parse(localStorage.getItem('puzero_chat_history') || '[]'),
            systemPrompt: localStorage.getItem('puzero_system_prompt') || "Kamu adalah AI asisten dari PuZero yang ramah dan membantu.",
            userId: localStorage.getItem('puzero_user_id') || ('user-' + Math.random().toString(36).substring(2, 15)),
            save() {
                if (this.chatHistory.length > 20) {
                    this.chatHistory = this.chatHistory.slice(-20);
                }
                localStorage.setItem('puzero_chat_history', JSON.stringify(this.chatHistory));
                localStorage.setItem('puzero_system_prompt', this.systemPrompt);
                localStorage.setItem('puzero_user_id', this.userId);
            }
        };
        window.PuZeroState.save();

        // Konfigurasi NProgress
        NProgress.configure({ showSpinner: false, speed: 400 });

        // 1. START: Jalankan saat HTMX mulai request
        document.addEventListener('htmx:beforeRequest', function(evt) {
            // CEK OTOMATIS: Jika ini navigasi BACK/FORWARD (history), JANGAN jalankan loading bar
            if (evt.detail.historyRestoreRequest) return;
            
            NProgress.start();
        });

        // 2. STOP: Berhenti saat request selesai (Berhasil/Error)
        document.addEventListener('htmx:afterRequest', function() {
            NProgress.done();
        });

        // 3. FIX BUG HP (BFCache): Paksa stop jika user tekan tombol 'Back' di HP
        window.addEventListener('pageshow', function(event) {
            if (event.persisted) {
                NProgress.done();
            }
        });

        window.toggleMobileMenu = function(e) {
            if (e) e.stopPropagation();
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('mobile-icon');
            if (!menu) return;

            const isCurrentlyOpen = menu.style.maxHeight && menu.style.maxHeight !== '0px';
            
            if (!isCurrentlyOpen) {
                menu.style.maxHeight = menu.scrollHeight + 'px';
                if(icon) {
                    icon.classList.replace('ph-list', 'ph-x');
                    icon.classList.add('rotate-90');
                }
            } else {
                menu.style.maxHeight = '0px';
                if(icon) {
                    icon.classList.replace('ph-x', 'ph-list');
                    icon.classList.remove('rotate-90');
                }
            }
        };

        document.addEventListener('click', (e) => {
            const menu = document.getElementById('mobile-menu');
            const btn = document.getElementById('mobile-menu-button');
            
            if (menu && menu.style.maxHeight && menu.style.maxHeight !== '0px') {
                if (!menu.contains(e.target) && (!btn || !btn.contains(e.target))) {
                    window.toggleMobileMenu();
                }
            }
        });
    </script>
</body>
</html>
