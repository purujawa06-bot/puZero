<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="theme-color" content="#ffffff">
    <title><%= title %></title>
    
    <!-- Theme Script (Prevent FOUC) -->
    <script>
        if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark')
        } else {
            document.documentElement.classList.remove('dark')
        }
    </script>

    <!-- SEO Meta Tags -->
    <meta name="description" content="PuZero - Platform alat serbaguna bertenaga AI. Download video dari berbagai platform, konversi unit, dan tingkatkan produktivitas Anda dalam satu tempat.">
    <meta name="keywords" content="AI Downloader, Video Downloader, Productivity Tools, PuZero, Puru Zero, Web Tools">
    <meta name="author" content="Puru Zero">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://puzero.vercel.app/">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="Platform alat serbaguna bertenaga AI for produktivitas maksimal.">
    <meta property="og:image" content="/favicon.jpg">

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Tailwind CSS (production build) -->
    <link rel="stylesheet" href="/css/tailwind.css">
    
    <!-- HTMX -->
    <script defer src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- Phosphor Icons -->
    <script defer src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Video.js -->
    <link href="https://cdn.jsdelivr.net/npm/video.js@8.10.0/dist/video-js.min.css" rel="stylesheet">
    <script defer src="https://cdn.jsdelivr.net/npm/video.js@8.10.0/dist/video.min.js"></script>

    <!-- Marked.js for Markdown Parsing -->
    <script defer src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <!-- Custom Style -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        [x-cloak] { display: none !important; }
        :root {
            --primary-glow: radial-gradient(rgba(99, 102, 241, 0.15), rgba(99, 102, 241, 0));
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        .htmx-indicator { display: none; }
        .htmx-request.htmx-indicator, .htmx-request .htmx-indicator { display: block; }

        .btn-hover-effect {
            position: relative;
            overflow: hidden;
            transform: translateZ(0);
        }
        .btn-hover-effect::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
            will-change: width, height;
        }
        .btn-hover-effect:active::after {
            width: 300%;
            height: 300%;
        }

        /* Video.js Centering Fix */
        .video-js .vjs-big-play-button {
            top: 50% !important;
            left: 50% !important;
            transform: translate(-50%, -50%) !important;
        }
    </style>
</head>
<body 
    x-data="{ 
        loading: false, 
        darkMode: localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches),
        currentPath: window.location.pathname
    }" 
    @htmx:before-request.window="loading = true" 
    @htmx:after-request.window="loading = false"
    @htmx:after-swap.window="currentPath = window.location.pathname"
    @popstate.window="currentPath = window.location.pathname"
    class="bg-[#f8fafc] text-slate-900 dark:bg-slate-950 dark:text-slate-100 min-h-[100dvh] flex flex-col antialiased selection:bg-primary/20 selection:text-primary pb-safe transition-all duration-300"
    :class="currentPath.startsWith('/anime') ? 'pb-16 md:pb-0' : ''"
>

    <!-- Global Loading Bar -->
    <div 
        x-show="loading" 
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0"
        x-transition:enter-end="opacity-100"
        x-transition:leave="transition ease-in duration-200"
        x-transition:leave-start="opacity-100"
        x-transition:leave-end="opacity-0"
        class="fixed top-0 left-0 w-full h-1 z-[200] pointer-events-none bg-slate-100 dark:bg-slate-800 overflow-hidden hw-accelerate"
    >
        <div class="h-full bg-emerald-50 w-1/3 animate-loading-bar hw-accelerate"></div>
    </div>

    <%- include('partials/navbar') %>

    <main id="main-content" class="flex-grow flex flex-col">
        <div class="fade-in flex-grow flex flex-col hw-accelerate">
            <% if (typeof page !== 'undefined') { %>
                <%- include(page) %>
            <% } else if (typeof body !== 'undefined') { %>
                <%- body %>
            <% } %>
        </div>
    </main>

    <%- include('partials/footer') %>

    <%- include('partials/bottom-nav') %>

    <!-- Global Scripts -->
    <script src="/js/index.js" defer></script>

    <script>
        window.PuZeroState = {
            chatHistory: JSON.parse(localStorage.getItem('puzero_chat_history') || '[]'),
            systemPrompt: localStorage.getItem('puzero_system_prompt') || "Kamu adalah AI asisten dari PuZero yang ramah dan membantu.",
            userId: localStorage.getItem('puzero_user_id') || ('user-' + Math.random().toString(36).substring(2, 15)),
            save() {
                if (this.chatHistory.length > 20) {
                    this.chatHistory = this.chatHistory.slice(-20);
                }
                localStorage.setItem('puzero_chat_history', JSON.stringify(this.chatHistory));
                localStorage.setItem('puzero_system_prompt', this.systemPrompt);
                localStorage.setItem('puzero_user_id', this.userId);
            }
        };
        window.PuZeroState.save();

        window.toggleMobileMenu = function(e) {
            if (e) e.stopPropagation();
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('mobile-icon');
            if (!menu) return;

            const isCurrentlyOpen = menu.style.maxHeight && menu.style.maxHeight !== '0px';
            
            if (!isCurrentlyOpen) {
                menu.style.maxHeight = menu.scrollHeight + 'px';
                if(icon) {
                    icon.classList.replace('ph-list', 'ph-x');
                    icon.classList.add('rotate-90');
                }
            } else {
                menu.style.maxHeight = '0px';
                if(icon) {
                    icon.classList.replace('ph-x', 'ph-list');
                    icon.classList.remove('rotate-90');
                }
            }
        };

        window.toggleTheme = function() {
            const isDark = document.documentElement.classList.toggle('dark');
            localStorage.theme = isDark ? 'dark' : 'light';
            return isDark;
        };

        document.addEventListener('click', (e) => {
            const menu = document.getElementById('mobile-menu');
            const btn = document.getElementById('mobile-menu-button');
            
            if (menu && menu.style.maxHeight && menu.style.maxHeight !== '0px') {
                if (!menu.contains(e.target) && (!btn || !btn.contains(e.target))) {
                    window.toggleMobileMenu();
                }
            }
        });
    </script>
</body>
</html>