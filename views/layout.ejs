<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content="PuZero - Platform alat serbaguna bertenaga AI. Download video dari berbagai platform, konversi unit, dan tingkatkan produktivitas Anda dalam satu tempat.">
    <meta name="keywords" content="AI Downloader, Video Downloader, Productivity Tools, PuZero, Puru Zero, Web Tools">
    <meta name="author" content="Puru Zero">
    <meta name="robots" content="index, follow">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://puzero.vercel.app/">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="Platform alat serbaguna bertenaga AI for produktivitas maksimal.">
    <meta property="og:image" content="/favicon.jpg">

    <!-- Tailwind CSS (with Typography Plugin for Markdown) -->
    <script src="https://cdn.tailwindcss.com?plugins=typography"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { 
                        primary: '#6366f1',
                        secondary: '#0f172a',
                        accent: '#f43f5e'
                    },
                    animation: {
                        'blob': 'blob 7s infinite',
                        'spin-slow': 'spin 3s linear infinite',
                    },
                    keyframes: {
                        blob: {
                            '0%': { transform: 'translate(0px, 0px) scale(1)' },
                            '33%': { transform: 'translate(30px, -50px) scale(1.1)' },
                            '66%': { transform: 'translate(-20px, 20px) scale(0.9)' },
                            '100%': { transform: 'translate(0px, 0px) scale(1)' },
                        }
                    }
                }
            }
        }
    </script>
    
    <!-- HTMX -->
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- NProgress (Navigation Loader) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/nprogress/0.2.0/nprogress.min.js"></script>

    <!-- Marked.js for Markdown Parsing -->
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

    <style>
        :root {
            --primary-glow: radial-gradient(rgba(99, 102, 241, 0.15), rgba(99, 102, 241, 0));
        }

        body { 
            font-family: 'Plus Jakarta Sans', sans-serif;
            scroll-behavior: smooth;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: #f1f1f1; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }

        .htmx-indicator { display: none; }
        .htmx-request.htmx-indicator, .htmx-request .htmx-indicator { display: block; }

        /* Global Animations */
        .fade-in { animation: fadeIn 0.5s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes fadeIn { 
            from { opacity: 0; transform: translateY(15px); } 
            to { opacity: 1; transform: translateY(0); } 
        }

        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); }
        
        .btn-hover-effect {
            position: relative;
            overflow: hidden;
        }
        .btn-hover-effect::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255, 255, 255, 0.2);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }
        .btn-hover-effect:active::after {
            width: 300%;
            height: 300%;
        }

        /* Custom NProgress */
        #nprogress .bar { background: #6366f1 !important; height: 3px !important; }
        #nprogress .peg { box-shadow: 0 0 10px #6366f1, 0 0 5px #6366f1 !important; }
        #nprogress .spinner-icon { border-top-color: #6366f1 !important; border-left-color: #6366f1 !important; }
    </style>
</head>
<body class="bg-[#f8fafc] text-slate-900 min-h-screen flex flex-col antialiased">

    <%- include('partials/navbar') %>

    <main id="main-content" class="flex-grow">
        <div class="fade-in">
            <% if (typeof page !== 'undefined') { %>
                <%- include(page) %>
            <% } else if (typeof body !== 'undefined') { %>
                <%- body %>
            <% } %>
        </div>
    </main>

    <% if (typeof page !== 'undefined' && page !== 'pages/ai-chat' && page !== 'pages/instagram-downloader') { %>
        <%- include('partials/footer') %>
    <% } %>

    <script>
        // Global Windows State (Persistence with LocalStorage)
        window.PuZeroState = {
            chatHistory: JSON.parse(localStorage.getItem('puzero_chat_history') || '[]'),
            systemPrompt: localStorage.getItem('puzero_system_prompt') || "Kamu adalah AI asisten dari PuZero yang ramah dan membantu.",
            userId: localStorage.getItem('puzero_user_id') || ('user-' + Math.random().toString(36).substring(2, 15)),
            save() {
                // Keep only the last 20 messages
                if (this.chatHistory.length > 20) {
                    this.chatHistory = this.chatHistory.slice(-20);
                }
                localStorage.setItem('puzero_chat_history', JSON.stringify(this.chatHistory));
                localStorage.setItem('puzero_system_prompt', this.systemPrompt);
                localStorage.setItem('puzero_user_id', this.userId);
            }
        };
        // Initial save to persist userId if it's new
        window.PuZeroState.save();

        // Setup NProgress integration with HTMX
        NProgress.configure({ showSpinner: true, minimum: 0.2 });
        document.addEventListener('htmx:beforeRequest', (e) => {
            if (e.detail.headers && e.detail.headers['X-Skip-NProgress']) return;
            NProgress.start();
        });
        document.addEventListener('htmx:afterOnLoad', () => NProgress.done());
        document.addEventListener('htmx:afterRequest', (e) => {
            if (e.detail.failed) NProgress.done();
        });

        document.addEventListener('DOMContentLoaded', () => {
            const btn = document.getElementById('mobile-menu-button');
            const menu = document.getElementById('mobile-menu');
            const icon = document.getElementById('mobile-icon');
            
            let isOpen = false;

            window.toggleMobileMenu = function() {
                isOpen = !isOpen;
                if (isOpen) {
                    menu.style.maxHeight = menu.scrollHeight + 'px';
                    if(icon) {
                        icon.classList.replace('ph-list', 'ph-x');
                        icon.classList.add('rotate-90');
                    }
                } else {
                    menu.style.maxHeight = '0px';
                    if(icon) {
                        icon.classList.replace('ph-x', 'ph-list');
                        icon.classList.remove('rotate-90');
                    }
                }
            };

            if (btn) {
                btn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    window.toggleMobileMenu();
                });
            }

            document.addEventListener('click', (e) => {
                if (isOpen && menu && !menu.contains(e.target)) {
                    window.toggleMobileMenu();
                }
            });
        });
    </script>
</body>
</html>
