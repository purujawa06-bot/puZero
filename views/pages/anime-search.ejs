<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        <div class="mb-10 md:mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-secondary tracking-tight mb-2 md:mb-3">
                    Hasil <span class="text-primary">Cari</span>
                </h1>
                <p class="text-slate-500 text-sm sm:text-base font-medium">
                    Menampilkan hasil untuk: "<%= query %>"
                </p>
            </div>

            <div class="flex flex-col sm:flex-row items-center gap-3 w-full md:w-auto">
                <button hx-get="/anime" hx-target="#main-content" hx-push-url="true" class="w-full sm:w-auto px-6 py-3.5 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary transition-all shadow-sm">
                    Kembali ke Home
                </button>
                <div class="w-full md:w-80">
                    <form hx-get="/anime/search" hx-target="#main-content" hx-push-url="true" class="relative group">
                        <input type="text" name="q" value="<%= query %>" placeholder="Cari lagi..." class="w-full pl-12 pr-4 py-3.5 bg-white border border-slate-200 rounded-2xl focus:outline-none focus:border-primary transition-all font-bold text-sm shadow-sm">
                        <i class="ph-bold ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400"></i>
                    </form>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
            <% if (animeList && animeList.length > 0) { %>
                <% animeList.forEach(anime => { %>
                    <div hx-get="/anime/detail/<%= anime.slug %>" hx-target="#main-content" hx-push-url="true" class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:border-primary/20 transition-all duration-300 cursor-pointer flex flex-col">
                        <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
                            <img src="<%= anime.thumb %>" alt="<%= anime.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-2.5 left-2.5">
                                <span class="px-2.5 py-1 bg-primary text-white text-[9px] font-black rounded-lg shadow-md uppercase">
                                    <%= anime.ep %>
                                </span>
                            </div>
                        </div>
                        <div class="p-4 flex flex-col flex-grow">
                            <h3 class="text-xs font-bold text-secondary line-clamp-2 mb-2 group-hover:text-primary transition-colors flex-grow">
                                <%= anime.title %>
                            </h3>
                            <div class="mt-auto pt-2 border-t border-slate-50">
                                <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest line-clamp-1"><%= anime.uploaded %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-300">
                        <i class="ph-bold ph-magnifying-glass text-3xl"></i>
                    </div>
                    <p class="text-slate-400 font-bold text-sm">Anime tidak ditemukan.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
