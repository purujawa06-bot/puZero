<title><%= title %></title>
<div class="max-w-4xl mx-auto h-[100dvh] flex flex-col fade-in relative overflow-hidden">
    
    <!-- Top Header -->
    <div class="flex items-center justify-between px-4 sm:px-6 py-4 bg-slate-900/90 backdrop-blur-md sticky top-0 z-10 border-b border-slate-800 shadow-sm shrink-0">
        <div class="flex items-center gap-3 md:gap-4">
            <button 
                hx-get="/category" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="w-9 h-9 md:w-10 md:h-10 flex items-center justify-center rounded-xl bg-slate-800 text-slate-400 hover:bg-rose-500 hover:text-white transition-all border border-slate-700"
            >
                <i class="ph-bold ph-arrow-left text-lg md:text-xl"></i>
            </button>
            <div>
                <h1 class="text-lg md:text-xl font-black text-white tracking-tight">Tsundere AI</h1>
                <div class="flex items-center gap-1.5 mt-0.5">
                    <span class="w-2 h-2 bg-rose-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(244,63,94,0.5)]"></span>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Tsun-Tsun Mode</span>
                </div>
            </div>
        </div>

        <button 
            onclick="resetChat()" 
            class="px-3 md:px-4 py-2 bg-slate-800 border border-slate-700 text-slate-300 rounded-xl text-xs font-bold hover:border-rose-500 hover:text-rose-500 transition-all flex items-center gap-2 active:scale-95 shadow-sm"
        >
            <i class="ph-bold ph-plus"></i> <span class="hidden sm:inline">New Chat</span>
        </button>
    </div>

    <!-- Chat Area -->
    <div id="chat-window" class="flex-grow overflow-y-auto px-4 sm:px-6 py-6 space-y-6 custom-scrollbar pb-32">
        <div id="welcome" class="text-center py-12 md:py-20 max-w-lg mx-auto">
            <div class="w-16 h-16 md:w-20 md:h-20 bg-gradient-to-tr from-rose-500/20 to-pink-500/20 text-rose-500 rounded-3xl mx-auto flex items-center justify-center mb-6 border border-slate-800 shadow-sm">
                <i class="ph-fill ph-heart-break text-3xl md:text-4xl"></i>
            </div>
            <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">B-Bukan berarti aku mau bantu ya!</h2>
            <p class="text-slate-400 text-sm md:text-base mt-3 leading-relaxed">Jangan salah paham, aku cuma lagi bosan aja. Mau tanya apa? Dasar baka!</p>
        </div>
        
        <div id="chat-messages" class="flex flex-col space-y-6"></div>
        
        <div id="chat-loading" class="hidden mb-4">
            <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-slate-800 rounded-xl animate-pulse flex items-center justify-center shrink-0">
                    <i class="ph-bold ph-heart text-rose-400"></i>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl rounded-tl-none w-24 shadow-sm">
                    <div class="flex gap-1.5 justify-center">
                        <span class="w-2 h-2 bg-rose-500/40 rounded-full animate-bounce" style="animation-delay: 0s"></span>
                        <span class="w-2 h-2 bg-rose-500/60 rounded-full animate-bounce" style="animation-delay: 0.1s"></span>
                        <span class="w-2 h-2 bg-rose-500/80 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                    </div>
                </div>
            </div>
        </div>
        <div id="scroll-anchor" class="h-4 w-full"></div>
    </div>

    <!-- Input Area -->
    <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-slate-950 via-slate-950 to-transparent shrink-0">
        <div class="max-w-3xl mx-auto">
            <div class="bg-slate-900 rounded-2xl shadow-2xl shadow-slate-950 border border-slate-800 p-2 md:p-3 transition-all focus-within:border-rose-500/40 focus-within:shadow-rose-500/5">
                <div class="flex flex-col gap-2">
                    <div class="flex items-end gap-2 px-2 pb-1">
                        <textarea 
                            id="prompt-textarea"
                            class="w-full bg-transparent border-none focus:ring-0 text-slate-200 text-base md:text-sm py-2 resize-none max-h-32 overflow-y-auto custom-scrollbar placeholder:text-slate-500" 
                            rows="1" 
                            placeholder="Ketik sesuatu, baka..."
                            oninput="this.style.height = ''; this.style.height = Math.min(this.scrollHeight, 120) + 'px'"
                            onkeydown="if(event.keyCode == 13 && !event.shiftKey) { event.preventDefault(); sendMessage(); }"
                        ></textarea>
                        
                        <button onclick="sendMessage()" class="w-10 h-10 md:w-12 md:h-12 bg-rose-500 text-white rounded-xl flex items-center justify-center hover:bg-rose-600 transition-all shadow-md active:scale-90 shrink-0 mb-1">
                            <i class="ph-bold ph-paper-plane-right text-lg md:text-xl"></i>
                        </button>
                    </div>
                </div>
            </div>
            <p class="text-[10px] text-center text-slate-500 mt-2 font-medium">B-Baka! Jangan tanya yang aneh-aneh!</p>
        </div>
    </div>
</div>

<script>
    (function() {
        const escapeHtml = (u) => (u || "").toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");

        const chatMessages = document.getElementById('chat-messages');
        const promptInput = document.getElementById('prompt-textarea');
        const welcomeDiv = document.getElementById('welcome');
        const scrollAnchor = document.getElementById('scroll-anchor');
        const loadingDiv = document.getElementById('chat-loading');

        const getLocalState = () => {
            return {
                history: JSON.parse(localStorage.getItem('puzero_tsundere_history') || '[]'),
            };
        };

        const saveLocalState = (data) => {
            if (data.history) localStorage.setItem('puzero_tsundere_history', JSON.stringify(data.history.slice(-20)));
        };

        const scrollToBottom = () => scrollAnchor.scrollIntoView({ behavior: 'smooth', block: 'end' });

        window.resetChat = function() {
            if(confirm('Mulai chat baru? Ingatan aku bakal ilang, baka!')) {
                saveLocalState({ history: [] });
                chatMessages.innerHTML = '';
                welcomeDiv.classList.remove('hidden');
            }
        };

        window.sendMessage = async function() {
            const prompt = promptInput.value.trim();
            if(!prompt) return;

            welcomeDiv.classList.add('hidden');
            const safePrompt = escapeHtml(prompt);
            
            chatMessages.insertAdjacentHTML('beforeend', `
                <div class="flex flex-col items-end space-y-1.5 group animate-fade-in w-full">
                    <div class="max-w-[90%] md:max-w-[80%] bg-rose-500 text-white p-3.5 md:p-4 rounded-2xl rounded-tr-sm shadow-sm relative overflow-hidden">
                        <p class="text-sm md:text-base whitespace-pre-wrap break-words">${safePrompt}</p>
                    </div>
                </div>
            `);

            promptInput.value = '';
            promptInput.style.height = 'auto';
            scrollToBottom();
            loadingDiv.classList.remove('hidden');

            try {
                const res = await fetch('/ai/tsundere', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        text: prompt
                    })
                });

                const data = await res.json();
                if (!data.success) throw new Error(data.message || "Gagal mendapatkan respon");

                const aiText = data.result?.text || data.result || "";
                const aiAudio = data.result?.audio || null;

                const audioId = 'audio-' + Date.now();
                const audioHtml = aiAudio
                    ? `<div class="mt-3 flex items-center gap-2">
                          <button onclick="toggleAudio('${audioId}')" class="flex items-center gap-2 px-3 py-1.5 bg-rose-500/10 border border-rose-500/30 text-rose-400 rounded-xl text-xs font-bold hover:bg-rose-500/20 transition-all active:scale-95">
                              <i class="ph-bold ph-speaker-high text-sm" id="icon-${audioId}"></i>
                              <span id="label-${audioId}">Putar Suara</span>
                          </button>
                          <audio id="${audioId}" src="${aiAudio}" onended="resetAudioBtn('${audioId}')"></audio>
                       </div>`
                    : '';

                const aiHtml = `
                    <div class="flex flex-col items-start space-y-1.5 group opacity-0 animate-fade-in w-full" style="animation: fadeIn 0.4s forwards">
                        <div class="max-w-[95%] md:max-w-[85%] bg-slate-900 border border-slate-800 p-4 md:p-5 rounded-2xl rounded-tl-sm shadow-sm relative overflow-hidden">
                            <div class="flex items-center gap-2 mb-3">
                                <div class="w-6 h-6 bg-gradient-to-tr from-rose-500 to-pink-500 rounded-[0.4rem] flex items-center justify-center shrink-0">
                                     <i class="ph-fill ph-heart text-white text-[10px]"></i>
                                </div>
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tsundere AI</span>
                            </div>
                            <div class="prose prose-sm md:prose-base prose-slate dark:prose-invert max-w-none text-slate-300 leading-relaxed overflow-x-auto break-words ai-content">${marked.parse(aiText)}</div>
                            ${audioHtml}
                        </div>
                    </div>
                `;
                chatMessages.insertAdjacentHTML('beforeend', aiHtml);
                
                const currentState = getLocalState();
                const updatedHistory = currentState.history;
                updatedHistory.push({ role: 'user', text: prompt });
                updatedHistory.push({ role: 'model', text: aiText });
                saveLocalState({ history: updatedHistory });
                
            } catch (err) {
                chatMessages.insertAdjacentHTML('beforeend', `<div class="p-3 text-red-400 text-xs md:text-sm bg-red-900/20 rounded-xl max-w-[80%] border border-red-800/50">❌ Error: ${err.message}</div>`);
            } finally {
                loadingDiv.classList.add('hidden');
                scrollToBottom();
            }
        };

        function renderHistory() {
            const hist = getLocalState().history;
            if (hist.length > 0) {
                welcomeDiv.classList.add('hidden');
                hist.forEach(msg => {
                    let html = '';
                    if (msg.role === 'user') {
                        html = `
                            <div class="flex flex-col items-end space-y-1.5 w-full mb-4">
                                <div class="max-w-[90%] md:max-w-[80%] bg-rose-500 text-white p-3.5 md:p-4 rounded-2xl rounded-tr-sm shadow-sm relative overflow-hidden">
                                    <p class="text-sm md:text-base whitespace-pre-wrap break-words">${escapeHtml(msg.text)}</p>
                                </div>
                            </div>`;
                    } else {
                        html = `
                            <div class="flex flex-col items-start space-y-1.5 group w-full mb-4">
                                <div class="max-w-[95%] md:max-w-[85%] bg-slate-900 border border-slate-800 p-4 md:p-5 rounded-2xl rounded-tl-sm shadow-sm relative overflow-hidden">
                                    <div class="flex items-center gap-2 mb-3">
                                        <div class="w-6 h-6 bg-gradient-to-tr from-rose-500 to-pink-500 rounded-[0.4rem] flex items-center justify-center shrink-0">
                                            <i class="ph-fill ph-heart text-white text-[10px]"></i>
                                        </div>
                                        <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Tsundere AI</span>
                                    </div>
                                    <div class="prose prose-sm md:prose-base prose-slate dark:prose-invert max-w-none text-slate-300 leading-relaxed overflow-x-auto break-words ai-content">${marked.parse(msg.text)}</div>
                                </div>
                            </div>`;
                    }
                    chatMessages.insertAdjacentHTML('beforeend', html);
                });
                setTimeout(scrollToBottom, 100);
            }
        }
        renderHistory();
    })();

    window.toggleAudio = function(id) {
        const audio = document.getElementById(id);
        const icon = document.getElementById('icon-' + id);
        const label = document.getElementById('label-' + id);
        if (!audio) return;
        if (audio.paused) {
            document.querySelectorAll('audio').forEach(a => { if (a.id !== id) { a.pause(); a.currentTime = 0; } });
            audio.play();
            icon.className = 'ph-bold ph-pause text-sm';
            label.textContent = 'Pause';
        } else {
            audio.pause();
            icon.className = 'ph-bold ph-speaker-high text-sm';
            label.textContent = 'Putar Suara';
        }
    };

    window.resetAudioBtn = function(id) {
        const icon = document.getElementById('icon-' + id);
        const label = document.getElementById('label-' + id);
        if (icon) icon.className = 'ph-bold ph-speaker-high text-sm';
        if (label) label.textContent = 'Putar Suara';
    };
</script>