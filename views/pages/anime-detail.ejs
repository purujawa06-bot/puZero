<title><%= title %></title>
<div class="relative min-h-screen fade-in">
    <!-- Hero Background Blur -->
    <div class="absolute top-0 left-0 w-full h-[400px] overflow-hidden -z-10 hw-accelerate">
        <img src="<%= detail.thumb %>" loading="lazy" decoding="async" class="w-full h-full object-cover blur-3xl opacity-20 scale-110">
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-[#f8fafc]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4 pt-10 pb-24">
        <!-- Back Button -->
        <div class="mb-8">
            <button 
                hx-get="/anime" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-all group hw-accelerate"
            >
                <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 group-hover:border-primary/30 group-hover:bg-primary/5 shadow-sm">
                    <i class="fas fa-arrow-left"></i>
                </div>
                Kembali ke Daftar
            </button>
        </div>

        <div class="flex flex-col lg:flex-row gap-10">
            <!-- Left Side: Poster & Meta -->
            <div class="w-full lg:w-72 shrink-0">
                <div class="sticky top-24 hw-accelerate">
                    <div class="relative rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white aspect-[3/4]">
                        <img src="<%= detail.thumb %>" loading="lazy" decoding="async" alt="<%= detail.title %>" class="w-full h-full object-cover">
                        <% if (detail.rating) { %>
                            <div class="absolute bottom-4 left-4 right-4 bg-white/90 backdrop-blur-md rounded-2xl p-3 flex items-center justify-between shadow-lg">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Score</span>
                                <div class="flex items-center gap-1 text-primary">
                                    <i class="fas fa-star text-amber-400"></i>
                                    <span class="font-bold text-sm text-secondary"><%= detail.rating %></span>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <div class="mt-8 space-y-4">
                        <% Object.keys(detail.info).forEach(key => { %>
                            <div class="flex justify-between items-start gap-4 p-3 bg-white/50 border border-slate-100 rounded-2xl">
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest mt-0.5"><%= key %></span>
                                <span class="text-xs font-bold text-secondary text-right"><%= detail.info[key] %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- Right Side: Content -->
            <div class="flex-grow space-y-10 content-auto">
                <div>
                    <h1 class="text-3xl md:text-5xl font-black text-secondary tracking-tight mb-4 leading-tight"><%= detail.title %></h1>
                    <div class="flex flex-wrap gap-2">
                        <% detail.genres.forEach(genre => { %>
                            <span class="px-4 py-1.5 bg-white border border-slate-200 text-slate-500 rounded-full text-[10px] font-black uppercase tracking-widest"><%= genre %></span>
                        <% }) %>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-sm relative overflow-hidden hw-accelerate">
                    <div class="absolute top-0 left-0 w-1 h-full bg-primary"></div>
                    <h3 class="text-lg font-black text-secondary mb-4 flex items-center gap-2">
                        <i class="fas fa-align-left text-primary"></i>
                        Sinopsis
                    </h3>
                    <p class="text-slate-500 leading-relaxed text-sm whitespace-pre-line">
                        <%= detail.synopsis %>
                    </p>
                </div>

                <div class="space-y-6">
                    <h3 class="text-xl font-black text-secondary flex items-center gap-3">
                        <i class="fas fa-list-ol text-primary"></i>
                        Daftar Episode
                    </h3>
                    
                    <div class="grid grid-cols-1 gap-3 content-auto">
                        <% detail.episodes.forEach(ep => { %>
                            <a 
                                hx-get="/anime/<%= ep.isEpisode ? 'stream' : 'detail' %>/<%= ep.slug %>"
                                hx-target="#main-content"
                                hx-push-url="true"
                                class="flex items-center justify-between p-5 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all group cursor-pointer hw-accelerate"
                            >
                                <div class="flex items-center gap-5 overflow-hidden">
                                    <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-primary group-hover:text-white transition-all shrink-0">
                                        <span class="text-sm font-black"><%= ep.eps %></span>
                                    </div>
                                    <div class="overflow-hidden">
                                        <h4 class="font-bold text-slate-700 text-sm truncate group-hover:text-primary transition-colors"><%= ep.title %></h4>
                                        <p class="text-[10px] text-slate-400 font-bold uppercase mt-1"><%= ep.date %></p>
                                    </div>
                                </div>
                                <div class="w-10 h-10 rounded-full bg-slate-50 flex items-center justify-center text-slate-300 group-hover:text-primary group-hover:bg-primary/5 transition-all shrink-0">
                                    <i class="fas fa-chevron-right"></i>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>