<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16" x-data="{ history: JSON.parse(localStorage.getItem('puzero_anime_history') || '[]') }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl font-extrabold text-secondary tracking-tight mb-2">
                    Riwayat <span class="text-primary">Tontonan</span>
                </h1>
                <p class="text-slate-500 text-sm font-medium">Lanjutkan petualangan anime Anda dari episode terakhir.</p>
            </div>
            
            <div class="flex items-center gap-3">
                <button @click="if(confirm('Hapus semua riwayat?')){ localStorage.removeItem('puzero_anime_history'); history = []; }" class="px-5 py-3 bg-white border border-slate-200 rounded-2xl text-red-500 font-bold hover:bg-red-50 transition-all shadow-sm flex items-center gap-2 hw-accelerate">
                    <i class="ph-bold ph-trash"></i> Bersihkan
                </button>
            </div>
        </div>

        <template x-if="history.length > 0">
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6 content-auto">
                <template x-for="anime in history" :key="anime.slug">
                    <div 
                        hx-get="" :hx-get="'/anime/stream/' + anime.slug"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:border-primary/20 transition-all duration-300 cursor-pointer flex flex-col hw-accelerate"
                    >
                        <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
                            <img :src="anime.thumb" loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-2 left-2">
                                <span class="px-2 py-1 bg-secondary/80 backdrop-blur-md text-white text-[9px] font-black rounded-lg uppercase" x-text="'Ep ' + anime.ep"></span>
                            </div>
                        </div>
                        <div class="p-4 flex flex-col flex-grow">
                            <h3 class="text-xs font-bold text-secondary line-clamp-2 mb-2 group-hover:text-primary transition-colors flex-grow" x-text="anime.baseTitle"></h3>
                            <div class="mt-auto pt-2 border-t border-slate-50">
                                <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest" x-text="new Date(anime.timestamp).toLocaleDateString()"></span>
                            </div>
                        </div>
                    </div>
                </template>
            </div>
        </template>

        <template x-if="history.length === 0">
            <div class="py-20 text-center">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-300">
                    <i class="ph-bold ph-ghost text-4xl"></i>
                </div>
                <h3 class="text-lg font-bold text-slate-700">Belum ada riwayat.</h3>
                <p class="text-slate-400 text-sm mt-1">Mulai menonton anime untuk melihat daftar di sini.</p>
                <button hx-get="/anime" hx-target="#main-content" class="mt-6 px-8 py-3 bg-primary text-white font-bold rounded-xl shadow-lg shadow-primary/20">Cari Anime</button>
            </div>
        </template>
    </div>
</div>