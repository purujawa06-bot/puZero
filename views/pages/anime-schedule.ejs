<title><%= title %></title>
<div class="relative overflow-hidden min-h-screen fade-in">
    <div class="max-w-6xl mx-auto px-4 pt-16 pb-24">
        <div class="mb-12 text-center md:text-left flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <h1 class="text-4xl font-extrabold text-secondary tracking-tight mb-2">
                    Jadwal <span class="text-primary">Rilis</span>
                </h1>
                <p class="text-slate-500 font-medium">Jangan lewatkan episode terbaru anime favoritmu.</p>
            </div>
        </div>

        <!-- Day Selector -->
        <div class="flex flex-wrap gap-2 mb-12 justify-center md:justify-start">
            <% dayList.forEach(day => { %>
                <button 
                    hx-get="/anime/schedule?day=<%= day %>"
                    hx-target="#main-content"
                    hx-push-url="true"
                    class="px-5 py-3 rounded-2xl text-sm font-bold transition-all border shadow-sm hw-accelerate <%= selectedDay === day ? 'bg-primary text-white border-primary shadow-primary/20 scale-105' : 'bg-white text-slate-500 border-slate-100 hover:border-primary/30' %>"
                >
                    <%= day.charAt(0).toUpperCase() + day.slice(1) %>
                </button>
            <% }) %>
        </div>

        <!-- Schedule List -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 content-auto">
            <% if (schedule && schedule.length > 0) { %>
                <% schedule.forEach(anime => { %>
                    <div 
                        hx-get="/anime/detail/<%= anime.slug %>"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="group bg-white p-4 rounded-[2rem] border border-slate-100 hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 cursor-pointer flex gap-5 items-center hw-accelerate"
                    >
                        <div class="w-24 h-32 rounded-2xl overflow-hidden shrink-0 shadow-lg">
                            <img src="<%= anime.featured_img_src %>" loading="lazy" decoding="async" alt="<%= anime.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                        </div>
                        <div class="flex-grow overflow-hidden">
                            <div class="flex items-center gap-2 mb-2">
                                <span class="px-2 py-0.5 bg-slate-100 text-slate-500 text-[9px] font-black rounded-md uppercase"><%= anime.east_type %></span>
                                <span class="text-[10px] text-amber-500 font-black"><i class="ph-fill ph-star"></i> <%= anime.east_score %></span>
                            </div>
                            <h3 class="text-sm font-bold text-secondary line-clamp-2 group-hover:text-primary transition-colors leading-snug mb-2">
                                <%= anime.title %>
                            </h3>
                            <div class="flex items-center gap-2 text-slate-400">
                                <i class="ph-bold ph-clock text-xs"></i>
                                <span class="text-[10px] font-bold uppercase tracking-widest"><%= anime.east_time %> WIB</span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                        <i class="ph-bold ph-calendar-blank text-4xl"></i>
                    </div>
                    <p class="text-slate-400 font-bold">Tidak ada jadwal rilis untuk hari ini.</p>
                </div>
            <% } %>
        </div>
    </div>
</div>
