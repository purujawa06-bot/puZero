<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        
        <!-- Header -->
        <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-10">
            <div class="text-center md:text-left">
                <button hx-get="/manga" hx-target="#main-content" hx-push-url="true" class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors font-bold text-xs mb-4">
                    <i class="ph-bold ph-arrow-left"></i> Kembali
                </button>
                <h1 class="text-3xl font-extrabold text-secondary tracking-tight">
                    Hasil Cari: <span class="text-primary">"<%= query %>"</span>
                </h1>
                <p class="text-slate-500 text-sm font-medium mt-1">Ditemukan <%= mangaList.length %> judul manga yang cocok.</p>
            </div>

            <div class="w-full sm:w-64">
                <form hx-get="/manga/search" hx-target="#main-content" hx-push-url="true" class="relative group hw-accelerate">
                    <input type="text" name="q" value="<%= query %>" placeholder="Cari manga lain..." class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-2xl focus:outline-none focus:border-primary transition-all font-bold text-sm shadow-sm">
                    <i class="ph-bold ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors"></i>
                </form>
            </div>
        </div>

        <!-- Search Results Grid -->
        <% if (mangaList.length > 0) { %>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
                <% mangaList.forEach(manga => { %>
                    <% 
                       const urlParams = new URLSearchParams(manga.link.split('?')[1]);
                       const originalUrl = urlParams.get('url');
                    %>
                    <div hx-get="/manga/detail?url=<%= encodeURIComponent(originalUrl) %>" hx-target="#main-content" hx-push-url="true" class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:border-primary/20 transition-all duration-300 cursor-pointer hw-accelerate">
                        <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
                            <img src="<%= manga.thumbnail %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-2 left-2">
                                <span class="px-2 py-1 bg-primary text-white text-[9px] font-black rounded-lg uppercase shadow-lg"><%= manga.type %></span>
                            </div>
                        </div>
                        <div class="p-3">
                            <h3 class="text-xs font-bold text-secondary line-clamp-2 mb-1 group-hover:text-primary transition-colors"><%= manga.title %></h3>
                            <p class="text-[9px] text-slate-400 font-bold uppercase truncate"><%= manga.description %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="py-20 text-center">
                <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                    <i class="ph-bold ph-magnifying-glass text-4xl"></i>
                </div>
                <h2 class="text-xl font-bold text-secondary">Tidak ada hasil</h2>
                <p class="text-slate-400 text-sm mt-1">Coba gunakan kata kunci yang lebih umum.</p>
            </div>
        <% } %>

    </div>
</div>