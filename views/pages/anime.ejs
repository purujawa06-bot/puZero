<title><%= title %></title>
<div class="relative overflow-hidden min-h-screen fade-in">
    <div class="max-w-6xl mx-auto px-4 pt-16 pb-24">
        <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-4xl font-extrabold text-secondary tracking-tight mb-4">
                    <%= query ? 'Hasil' : 'Update' %> <span class="text-primary">Anime</span>
                </h1>
                <p class="text-slate-500 font-medium">
                    <%= query ? `Menampilkan hasil untuk: "${query}"` : 'Nonton anime sub indo terbaru langsung dari Samehadaku.' %>
                </p>
            </div>

            <!-- Search Bar -->
            <div class="w-full md:w-80">
                <form 
                    hx-get="/anime/search" 
                    hx-target="#main-content" 
                    hx-push-url="true"
                    class="relative group"
                >
                    <input 
                        type="text" 
                        name="q" 
                        value="<%= query || '' %>"
                        placeholder="Cari judul anime..." 
                        class="w-full pl-12 pr-4 py-3 bg-white border border-slate-200 rounded-2xl focus:outline-none focus:border-primary focus:ring-4 focus:ring-primary/5 transition-all font-bold text-sm shadow-sm"
                    >
                    <i class="ph-bold ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-lg group-focus-within:text-primary transition-colors"></i>
                </form>
            </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            <% if (animeList && animeList.length > 0) { %>
                <% animeList.forEach(anime => { %>
                    <div 
                        hx-get="/anime/detail/<%= anime.slug %>"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="group bg-white rounded-[2rem] border border-slate-100 overflow-hidden hover:shadow-2xl hover:shadow-primary/10 transition-all duration-500 cursor-pointer"
                    >
                        <div class="relative aspect-[3/4] overflow-hidden">
                            <img src="<%= anime.thumb %>" alt="<%= anime.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                            <div class="absolute top-4 left-4">
                                <span class="px-3 py-1 bg-primary text-white text-[10px] font-black rounded-full shadow-lg">
                                    <%= anime.ep.toUpperCase() %>
                                </span>
                            </div>
                        </div>
                        <div class="p-5">
                            <h3 class="text-sm font-bold text-secondary line-clamp-2 mb-2 group-hover:text-primary transition-colors h-10">
                                <%= anime.title %>
                            </h3>
                            <div class="flex items-center justify-between mt-4">
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest"><%= anime.uploaded %></span>
                                <div class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center text-slate-400 group-hover:bg-primary group-hover:text-white transition-all">
                                    <i class="ph-bold ph-play"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mx-auto mb-4 text-slate-300">
                        <i class="ph-bold ph-magnifying-glass text-4xl"></i>
                    </div>
                    <p class="text-slate-400 font-bold">Anime tidak ditemukan.</p>
                    <button hx-get="/anime" hx-target="#main-content" class="mt-4 text-primary font-bold text-sm">Kembali ke Update Terbaru</button>
                </div>
            <% } %>
        </div>
    </div>
</div>
