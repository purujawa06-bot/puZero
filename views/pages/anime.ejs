<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        
        <!-- Header -->
        <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-secondary tracking-tight mb-2">
                    Update <span class="text-primary">Anime</span>
                </h1>
                <p class="text-slate-500 text-sm font-medium">Nonton anime sub indo terbaru dengan kualitas terbaik.</p>
            </div>

            <div class="flex flex-wrap items-center justify-center md:justify-end gap-3">
                <button hx-get="/anime/list" hx-target="#main-content" hx-push-url="true" class="px-5 py-3 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm flex items-center gap-2 hw-accelerate">
                    <i class="ph-bold ph-list"></i> Semua Anime
                </button>
                <div class="w-full sm:w-64">
                    <form hx-get="/anime/search" hx-target="#main-content" hx-push-url="true" class="relative group hw-accelerate">
                        <input type="text" name="q" placeholder="Cari anime..." class="w-full pl-10 pr-4 py-3 bg-white border border-slate-200 rounded-2xl focus:outline-none focus:border-primary transition-all font-bold text-sm shadow-sm">
                        <i class="ph-bold ph-magnifying-glass absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-primary transition-colors"></i>
                    </form>
                </div>
            </div>
        </div>

        <!-- Section: Latest Updates -->
        <div class="mb-16">
            <h2 class="text-xl font-black text-secondary mb-6 flex items-center gap-2">
                <i class="ph-bold ph-clock-counter-clockwise text-primary"></i> Update Terbaru
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6 content-auto">
                <% latestUpdates.forEach(anime => { %>
                    <div hx-get="/anime/detail/<%= anime.slug %>" hx-target="#main-content" hx-push-url="true" class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:border-primary/20 transition-all duration-300 cursor-pointer hw-accelerate">
                        <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
                            <img src="<%= anime.thumb %>" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-2 left-2">
                                <span class="px-2 py-1 bg-primary text-white text-[9px] font-black rounded-lg uppercase"><%= anime.ep %></span>
                            </div>
                        </div>
                        <div class="p-3">
                            <h3 class="text-xs font-bold text-secondary line-clamp-2 mb-1 group-hover:text-primary transition-colors"><%= anime.title %></h3>
                            <p class="text-[9px] text-slate-400 font-bold uppercase"><%= anime.uploaded %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Section: Top 10 Weekly -->
        <div class="mb-16">
            <h2 class="text-xl font-black text-secondary mb-6 flex items-center gap-2">
                <i class="ph-bold ph-trend-up text-amber-500"></i> Populer Minggu Ini
            </h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 content-auto">
                <% top10.forEach(anime => { %>
                    <div hx-get="/anime/detail/<%= anime.slug %>" hx-target="#main-content" hx-push-url="true" class="flex items-center gap-4 p-3 bg-white border border-slate-50 rounded-2xl hover:border-primary/20 transition-all cursor-pointer group shadow-sm hw-accelerate">
                        <div class="w-12 h-16 rounded-xl overflow-hidden shrink-0">
                            <img src="<%= anime.thumb %>" loading="lazy" decoding="async" class="w-full h-full object-cover">
                        </div>
                        <div class="overflow-hidden">
                            <h3 class="text-xs font-bold text-secondary truncate group-hover:text-primary transition-colors">#<%= anime.rank %> <%= anime.title %></h3>
                            <div class="flex items-center gap-1.5 mt-1">
                                <i class="ph-fill ph-star text-amber-400 text-[10px]"></i>
                                <span class="text-[10px] font-black text-slate-400"><%= anime.score %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Section: Movies -->
        <div class="content-auto">
            <h2 class="text-xl font-black text-secondary mb-6 flex items-center gap-2">
                <i class="ph-bold ph-film-strip text-rose-500"></i> Project & Movies
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% movies.forEach(movie => { %>
                    <div hx-get="/anime/detail/<%= movie.slug %>" hx-target="#main-content" hx-push-url="true" class="bg-white p-4 rounded-[2rem] border border-slate-100 flex gap-4 items-center group cursor-pointer hover:shadow-lg transition-all hw-accelerate">
                        <div class="w-20 h-28 rounded-2xl overflow-hidden shrink-0 shadow-md">
                            <img src="<%= movie.thumb %>" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        </div>
                        <div class="overflow-hidden">
                            <h3 class="text-sm font-bold text-secondary line-clamp-2 group-hover:text-primary transition-colors"><%= movie.title %></h3>
                            <p class="text-[10px] text-slate-400 font-bold mt-2 uppercase tracking-widest"><%= movie.date %></p>
                            <p class="text-[9px] text-primary font-bold mt-1 uppercase"><%= movie.genres %></p>
                        </div>
                    </div>
                <% }) %>
            </div>
        </div>

    </div>
</div>
