<title><%= title %></title>
<div class="max-w-3xl mx-auto py-16 px-4 fade-in">
    <div class="mb-8">
        <button 
            hx-get="/category" 
            hx-target="#main-content" 
            hx-push-url="true"
            class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-all group"
        >
            <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 group-hover:border-primary/30 group-hover:bg-primary/5">
                <i class="ph-bold ph-arrow-left"></i>
            </div>
            Kembali ke Kategori
        </button>
    </div>

    <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-pink-500/10 text-pink-500 mb-6 shadow-inner relative">
            <div class="absolute inset-0 bg-pink-500/20 blur-xl rounded-full animate-pulse"></div>
            <i class="ph-bold ph-instagram-logo text-4xl relative z-10"></i>
        </div>
        <h1 class="text-4xl font-black text-secondary tracking-tight">Instagram Downloader</h1>
        <p class="text-slate-500 mt-3 text-lg">Download Reels, Video, dan Foto Instagram dengan kualitas terbaik.</p>
    </div>

    <div class="bg-white p-2 rounded-[2.5rem] shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative">
        <div class="p-8">
            <div class="space-y-4">
                <div class="group">
                    <label for="url" class="block text-sm font-bold text-slate-700 mb-2 ml-1">Instagram Link</label>
                    <div class="relative">
                        <i class="ph-bold ph-link absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 text-xl group-focus-within:text-pink-500 transition-colors"></i>
                        <input 
                            type="url" 
                            id="insta-url" 
                            placeholder="https://www.instagram.com/reel/..." 
                            class="w-full pl-14 pr-6 py-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:bg-white focus:border-pink-500 focus:ring-4 focus:ring-pink-500/10 outline-none transition-all font-medium"
                            required
                        >
                    </div>
                </div>

                <button onclick="downloadInstagram()" id="insta-btn" class="w-full py-5 bg-secondary hover:bg-slate-800 text-white font-black rounded-2xl flex items-center justify-center gap-3 transition-all hover:shadow-xl active:scale-[0.98] btn-hover-effect">
                    <i class="ph-bold ph-download-simple text-xl"></i>
                    Ambil Media
                </button>
            </div>

            <div id="loading" class="hidden mt-10 text-center py-12">
                <div class="flex flex-col items-center justify-center space-y-6">
                    <div class="relative">
                        <div class="w-20 h-20 border-4 border-slate-100 rounded-full"></div>
                        <div class="absolute inset-0 w-20 h-20 border-4 border-pink-500 border-t-transparent rounded-full animate-spin"></div>
                        <div class="absolute inset-2 w-16 h-16 border-4 border-indigo-400 border-b-transparent rounded-full animate-spin-slow"></div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="ph-fill ph-instagram-logo text-pink-500 text-2xl animate-pulse"></i>
                        </div>
                    </div>
                    <div class="space-y-2">
                        <p class="text-sm font-black text-slate-800 tracking-widest uppercase">Fetching Data...</p>
                        <p class="text-xs text-slate-400 mt-2 italic">Ini mungkin memerlukan waktu beberapa detik.</p>
                    </div>
                </div>
            </div>

            <div id="result-container" class="mt-8"></div>
        </div>
    </div>
</div>

<script>
    async function downloadInstagram() {
        const url = document.getElementById('insta-url').value;
        const resultContainer = document.getElementById('result-container');
        const loading = document.getElementById('loading');
        const btn = document.getElementById('insta-btn');

        if (!url) return alert('Masukkan URL Instagram dulu!');

        resultContainer.innerHTML = '';
        loading.classList.remove('hidden');
        btn.disabled = true;

        try {
            const res = await fetch('https://puruboy-api.vercel.app/api/downloader/instagram', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url })
            });
            const data = await res.json();

            if (!data.success) throw new Error('Gagal mengambil data. Pastikan URL benar/publik.');

            const result = data.result;
            const mediaHtml = result.medias.map(media => `
                <div class="flex items-center justify-between p-4 bg-white border border-slate-100 rounded-xl shadow-sm mb-3">
                    <div class="flex flex-col">
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-wider">${media.quality} ${media.format}</span>
                        <span class="text-sm font-semibold text-slate-700">Ukuran: ${media.size}</span>
                    </div>
                    <a href="${media.url}" target="_blank" class="px-5 py-2.5 bg-primary hover:bg-indigo-700 text-white text-sm font-bold rounded-xl transition-all flex items-center gap-2">
                        <i class="ph-bold ph-download-simple"></i>
                        Download
                    </a>
                </div>
            `).join('');

            resultContainer.innerHTML = `
                <div class="animation-fade-in space-y-6">
                    <div class="relative group">
                        <img src="${result.thumbnail}" class="w-full h-56 object-cover rounded-3xl shadow-xl border-4 border-white">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent rounded-3xl flex items-end p-6">
                            <p class="text-white font-bold text-sm line-clamp-1">${result.title}</p>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest ml-1">Pilih Kualitas Media</h4>
                        ${mediaHtml}
                    </div>
                </div>
            `;
        } catch (err) {
            resultContainer.innerHTML = `<div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200">❌ Error: ${err.message}</div>`;
        } finally {
            loading.classList.add('hidden');
            btn.disabled = false;
        }
    }
</script>
