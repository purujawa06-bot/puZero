<title><%= title %></title>
<div class="relative overflow-hidden min-h-screen fade-in">
    <!-- Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] pointer-events-none -z-10">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[20%] right-[-5%] w-[30%] h-[30%] bg-accent/10 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4 pt-16 pb-24">
        <div class="mb-16 text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-extrabold text-secondary tracking-tight mb-4">
                Pilih <span class="text-primary">Layanan</span>
            </h1>
            <p class="text-slate-500 text-lg font-medium">Silakan pilih kategori alat yang ingin Anda gunakan.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Category: Downloader -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-blue-500/20 hover:border-b-blue-500">
                <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center mb-6 text-3xl group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-download-simple"></i>
                </div>
                <h3 class="text-xl font-black text-secondary mb-3">Downloader</h3>
                <div class="space-y-3">
                    <button 
                        hx-get="/instagram" 
                        hx-target="#main-content" 
                        hx-push-url="true"
                        class="w-full flex items-center justify-between p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer"
                    >
                        <span class="text-sm font-bold">Instagram Video</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Category: AI -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-purple-500/20 hover:border-b-purple-500">
                <div class="w-16 h-16 bg-purple-50 text-purple-500 rounded-2xl flex items-center justify-center mb-6 text-3xl group-hover:bg-purple-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-brain"></i>
                </div>
                <h3 class="text-xl font-black text-secondary mb-3">AI (Chat)</h3>
                <div class="space-y-3">
                    <button 
                        hx-get="/ai" 
                        hx-target="#main-content" 
                        hx-push-url="true"
                        class="w-full flex items-center justify-between p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer"
                    >
                        <span class="text-sm font-bold">Gemini 3 Flash</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Category: AI-Image -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm transition-all opacity-60 grayscale hover:grayscale-0 cursor-not-allowed group">
                <div class="w-16 h-16 bg-pink-50 text-pink-500 rounded-2xl flex items-center justify-center mb-6 text-3xl">
                    <i class="ph-bold ph-image"></i>
                </div>
                <h3 class="text-xl font-black text-secondary mb-3">AI-Image</h3>
                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-100 text-slate-400">
                    <i class="ph-fill ph-lock-key text-xs"></i>
                    <span class="text-[10px] font-black tracking-widest uppercase">Coming Soon</span>
                </div>
            </div>

            <!-- Category: Tools -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm transition-all opacity-60 grayscale hover:grayscale-0 cursor-not-allowed group">
                <div class="w-16 h-16 bg-orange-50 text-orange-500 rounded-2xl flex items-center justify-center mb-6 text-3xl">
                    <i class="ph-bold ph-wrench"></i>
                </div>
                <h3 class="text-xl font-black text-secondary mb-3">Utils Tools</h3>
                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-slate-100 text-slate-400">
                    <i class="ph-fill ph-lock-key text-xs"></i>
                    <span class="text-[10px] font-black tracking-widest uppercase">Coming Soon</span>
                </div>
            </div>
        </div>
    </div>
</div>
