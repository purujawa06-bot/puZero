<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-12">
    <!-- Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] pointer-events-none -z-10">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[20%] right-[-5%] w-[30%] h-[30%] bg-accent/10 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        <div class="mb-10 md:mb-16 text-center md:text-left">
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-secondary tracking-tight mb-3 md:mb-4">
                Pilih <span class="text-primary">Layanan</span>
            </h1>
            <p class="text-slate-500 text-base md:text-lg font-medium">Silakan pilih kategori alat yang ingin Anda gunakan.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
            <!-- Category: Downloader -->
            <div class="bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-blue-500/20 hover:border-b-blue-500">
                <div class="w-14 h-14 md:w-16 md:h-16 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center mb-5 md:mb-6 text-2xl md:text-3xl group-hover:bg-blue-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-download-simple"></i>
                </div>
                <h3 class="text-lg md:text-xl font-black text-secondary mb-3 md:mb-4">Downloader</h3>
                <div class="space-y-2.5">
                    <button hx-get="/youtube" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">YouTube</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                    <button hx-get="/instagram" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">Instagram</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                    <button hx-get="/tiktok" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">TikTok</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                    <button hx-get="/soundcloud" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">SoundCloud</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Category: AI -->
            <div class="bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-purple-500/20 hover:border-b-purple-500">
                <div class="w-14 h-14 md:w-16 md:h-16 bg-purple-50 text-purple-500 rounded-2xl flex items-center justify-center mb-5 md:mb-6 text-2xl md:text-3xl group-hover:bg-purple-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-brain"></i>
                </div>
                <h3 class="text-lg md:text-xl font-black text-secondary mb-3 md:mb-4">AI (Chat)</h3>
                <div class="space-y-2.5">
                    <button hx-get="/ai" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">Gemini 3 Flash</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Category: AI-Video -->
            <div class="bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-rose-500/20 hover:border-b-rose-500">
                <div class="w-14 h-14 md:w-16 md:h-16 bg-rose-50 text-rose-500 rounded-2xl flex items-center justify-center mb-5 md:mb-6 text-2xl md:text-3xl group-hover:bg-rose-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-video-camera"></i>
                </div>
                <h3 class="text-lg md:text-xl font-black text-secondary mb-3 md:mb-4">AI-Video</h3>
                <div class="space-y-2.5">
                    <button hx-get="/tools/dubbing" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">AI Dubbing</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>

            <!-- Category: AI-Image -->
            <div class="bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all duration-300 group hover:-translate-y-1 border-b-4 border-b-indigo-500/20 hover:border-b-indigo-500">
                <div class="w-14 h-14 md:w-16 md:h-16 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center mb-5 md:mb-6 text-2xl md:text-3xl group-hover:bg-indigo-500 group-hover:text-white transition-colors duration-300">
                    <i class="ph-bold ph-image"></i>
                </div>
                <h3 class="text-lg md:text-xl font-black text-secondary mb-3 md:mb-4">AI-Image</h3>
                <div class="space-y-2.5">
                    <button hx-get="/tools/upscale" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">Upscale Image</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                    <button hx-get="/tools/ghibli" hx-target="#main-content" hx-push-url="true" class="w-full flex items-center justify-between p-3.5 md:p-4 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item shadow-sm cursor-pointer">
                        <span class="text-sm font-bold">Ghibli Filter</span>
                        <div class="w-6 h-6 rounded-full bg-white/20 flex items-center justify-center group-hover/item:translate-x-1 transition-transform">
                            <i class="ph-bold ph-caret-right text-xs"></i>
                        </div>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
