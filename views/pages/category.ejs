<div class="relative overflow-hidden min-h-screen">
    <!-- Background Accents -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-[600px] pointer-events-none -z-10">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px]"></div>
        <div class="absolute bottom-[20%] right-[-5%] w-[30%] h-[30%] bg-accent/10 rounded-full blur-[100px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4 pt-16 pb-24">
        <div class="mb-16">
            <h1 class="text-4xl font-extrabold text-secondary tracking-tight mb-4">
                Pilih <span class="text-primary">Layanan</span>
            </h1>
            <p class="text-slate-500">Silakan pilih kategori alat yang ingin Anda gunakan.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <!-- Category: Downloader -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all group border-b-4 border-b-blue-500/20">
                <div class="w-14 h-14 bg-blue-50 text-blue-500 rounded-2xl flex items-center justify-center mb-6 text-2xl group-hover:bg-blue-500 group-hover:text-white transition-colors">
                    <i class="ph-bold ph-download-simple"></i>
                </div>
                <h3 class="text-xl font-bold text-secondary mb-3">Downloader</h3>
                <div class="space-y-3">
                    <a href="/instagram" class="flex items-center justify-between p-3 rounded-xl bg-slate-50 hover:bg-primary hover:text-white transition-all group/item">
                        <span class="text-sm font-bold">Instagram Video</span>
                        <i class="ph-bold ph-caret-right text-xs group-hover/item:translate-x-1 transition-transform"></i>
                    </a>
                </div>
            </div>

            <!-- Category: AI -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm transition-all opacity-70 cursor-not-allowed">
                <div class="w-14 h-14 bg-purple-50 text-purple-500 rounded-2xl flex items-center justify-center mb-6 text-2xl">
                    <i class="ph-bold ph-brain"></i>
                </div>
                <h3 class="text-xl font-bold text-secondary mb-3">AI (Chat)</h3>
                <p class="text-xs font-black text-slate-400 tracking-widest uppercase">Coming Soon</p>
            </div>

            <!-- Category: AI-Image -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm transition-all opacity-70 cursor-not-allowed">
                <div class="w-14 h-14 bg-pink-50 text-pink-500 rounded-2xl flex items-center justify-center mb-6 text-2xl">
                    <i class="ph-bold ph-image"></i>
                </div>
                <h3 class="text-xl font-bold text-secondary mb-3">AI-Image</h3>
                <p class="text-xs font-black text-slate-400 tracking-widest uppercase">Coming Soon</p>
            </div>

            <!-- Category: Tools -->
            <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm transition-all opacity-70 cursor-not-allowed">
                <div class="w-14 h-14 bg-orange-50 text-orange-500 rounded-2xl flex items-center justify-center mb-6 text-2xl">
                    <i class="ph-bold ph-wrench"></i>
                </div>
                <h3 class="text-xl font-bold text-secondary mb-3">Utils Tools</h3>
                <p class="text-xs font-black text-slate-400 tracking-widest uppercase">Coming Soon</p>
            </div>
        </div>
    </div>
</div>
