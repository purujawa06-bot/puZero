<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-8">
    <!-- Background -->
    <div class="absolute inset-0 pointer-events-none -z-10">
        <div class="absolute top-0 left-0 w-[40%] h-[40%] bg-primary/8 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-0 right-0 w-[35%] h-[35%] bg-accent/8 rounded-full blur-[90px]"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 sm:pt-12 md:pt-16">
        <!-- Header -->
        <div class="mb-8 sm:mb-10 md:mb-14 text-center sm:text-left">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/8 dark:bg-primary/15 text-primary text-xs font-bold mb-3">
                <i class="ph-bold ph-squares-four"></i> Semua Layanan
            </div>
            <h1 class="text-2xl sm:text-3xl md:text-5xl font-extrabold text-secondary dark:text-white tracking-tight mb-2">
                Pilih <span class="gradient-text">Layanan</span>
            </h1>
            <p class="text-slate-500 dark:text-slate-400 text-sm sm:text-base font-medium">Silakan pilih kategori alat yang ingin Anda gunakan.</p>
        </div>

        <!-- Category Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 sm:gap-5 stagger">

            <!-- Downloader -->
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 p-5 sm:p-6 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-sm hover:shadow-lg dark:hover:shadow-slate-900/50 group border-b-4 border-b-blue-400/20 hover:border-b-blue-500 transition-all duration-300">
                <div class="w-13 h-13 sm:w-14 sm:h-14 bg-blue-50 dark:bg-blue-500/10 text-blue-500 rounded-2xl flex items-center justify-center mb-4 text-2xl sm:text-3xl cat-icon shadow-inner">
                    <i class="ph-bold ph-download-simple"></i>
                </div>
                <h3 class="text-base sm:text-lg font-black text-secondary dark:text-white mb-1">Downloader</h3>
                <p class="text-xs text-slate-400 mb-4 font-medium">Unduh dari berbagai platform</p>
                <div class="space-y-2">
                    <button hx-get="/youtube" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-blue-500 hover:text-white dark:hover:bg-blue-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-red-100 dark:bg-red-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-youtube-logo text-red-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">YouTube</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                    <button hx-get="/instagram" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-blue-500 hover:text-white dark:hover:bg-blue-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-pink-100 dark:bg-pink-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-instagram-logo text-pink-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">Instagram</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                    <button hx-get="/tiktok" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-blue-500 hover:text-white dark:hover:bg-blue-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-slate-100 dark:bg-slate-600 flex items-center justify-center">
                                <i class="ph-bold ph-tiktok-logo text-slate-700 dark:text-slate-300 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">TikTok</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                    <button hx-get="/soundcloud" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-blue-500 hover:text-white dark:hover:bg-blue-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-orange-100 dark:bg-orange-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-soundcloud-logo text-orange-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">SoundCloud</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                </div>
            </div>

            <!-- AI Chat -->
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 p-5 sm:p-6 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-sm hover:shadow-lg dark:hover:shadow-slate-900/50 group border-b-4 border-b-violet-400/20 hover:border-b-violet-500 transition-all duration-300">
                <div class="w-13 h-13 sm:w-14 sm:h-14 bg-violet-50 dark:bg-violet-500/10 text-violet-500 rounded-2xl flex items-center justify-center mb-4 text-2xl sm:text-3xl cat-icon shadow-inner">
                    <i class="ph-bold ph-brain"></i>
                </div>
                <h3 class="text-base sm:text-lg font-black text-secondary dark:text-white mb-1">AI (Chat)</h3>
                <p class="text-xs text-slate-400 mb-4 font-medium">Asisten AI canggih berbasis Gemini</p>
                <div class="space-y-2">
                    <button hx-get="/ai" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-violet-500 hover:text-white dark:hover:bg-violet-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-violet-100 dark:bg-violet-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-sparkle text-violet-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">Gemini 3 Flash</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                </div>
            </div>

            <!-- AI Video -->
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 p-5 sm:p-6 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-sm hover:shadow-lg dark:hover:shadow-slate-900/50 group border-b-4 border-b-rose-400/20 hover:border-b-rose-500 transition-all duration-300">
                <div class="w-13 h-13 sm:w-14 sm:h-14 bg-rose-50 dark:bg-rose-500/10 text-rose-500 rounded-2xl flex items-center justify-center mb-4 text-2xl sm:text-3xl cat-icon shadow-inner">
                    <i class="ph-bold ph-video-camera"></i>
                </div>
                <h3 class="text-base sm:text-lg font-black text-secondary dark:text-white mb-1">AI-Video</h3>
                <p class="text-xs text-slate-400 mb-4 font-medium">Olah dan konversi video dengan AI</p>
                <div class="space-y-2">
                    <button hx-get="/tools/dubbing" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-rose-500 hover:text-white dark:hover:bg-rose-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-rose-100 dark:bg-rose-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-microphone text-rose-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">AI Dubbing</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                </div>
            </div>

            <!-- AI Image -->
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 p-5 sm:p-6 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-sm hover:shadow-lg dark:hover:shadow-slate-900/50 group border-b-4 border-b-indigo-400/20 hover:border-b-indigo-500 transition-all duration-300">
                <div class="w-13 h-13 sm:w-14 sm:h-14 bg-indigo-50 dark:bg-indigo-500/10 text-indigo-500 rounded-2xl flex items-center justify-center mb-4 text-2xl sm:text-3xl cat-icon shadow-inner">
                    <i class="ph-bold ph-image"></i>
                </div>
                <h3 class="text-base sm:text-lg font-black text-secondary dark:text-white mb-1">AI-Image</h3>
                <p class="text-xs text-slate-400 mb-4 font-medium">Tingkatkan dan filter gambar dengan AI</p>
                <div class="space-y-2">
                    <button hx-get="/tools/upscale" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-indigo-500 hover:text-white dark:hover:bg-indigo-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-indigo-100 dark:bg-indigo-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-arrows-out text-indigo-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">Upscale Image</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                    <button hx-get="/tools/ghibli" hx-target="#main-content" hx-push-url="true"
                        class="w-full flex items-center justify-between p-3 rounded-xl bg-slate-50 dark:bg-slate-700/50 hover:bg-indigo-500 hover:text-white dark:hover:bg-indigo-600 transition-all group/item cursor-pointer">
                        <div class="flex items-center gap-2.5">
                            <div class="w-6 h-6 rounded-lg bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center">
                                <i class="ph-bold ph-magic-wand text-emerald-500 text-xs"></i>
                            </div>
                            <span class="text-sm font-bold text-slate-700 dark:text-slate-200 group-hover/item:text-white">Ghibli Filter</span>
                        </div>
                        <i class="ph-bold ph-caret-right text-xs text-slate-400 group-hover/item:text-white group-hover/item:translate-x-0.5 transition-transform"></i>
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>
