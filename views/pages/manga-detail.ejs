<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        
        <!-- Breadcrumb & Back -->
        <div class="mb-8 flex flex-wrap items-center justify-between gap-4">
            <button hx-get="/manga" hx-target="#main-content" hx-push-url="true" class="flex items-center gap-2 text-slate-500 hover:text-primary transition-colors font-bold text-sm">
                <i class="ph-bold ph-arrow-left"></i> Kembali ke Manga
            </button>

            <% if (detail.chapters && detail.chapters.length > 0) { 
                const firstChapter = detail.chapters[detail.chapters.length - 1];
            %>
                <button 
                    hx-get="/manga/read?url=<%= encodeURIComponent(firstChapter.originalLink) %>&mangaUrl=<%= encodeURIComponent(originalUrl) %>" 
                    hx-target="#main-content" 
                    hx-push-url="true"
                    class="flex items-center gap-2 px-6 py-2.5 bg-primary text-white rounded-xl font-black text-xs uppercase tracking-widest hover:scale-105 transition-all shadow-lg shadow-primary/20"
                >
                    <i class="ph-bold ph-play"></i> Baca Chapter 1
                </button>
            <% } %>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10">
            <!-- Sidebar: Thumbnail & Info -->
            <div class="lg:col-span-4 flex flex-col gap-6">
                <div class="relative group">
                    <div class="aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white">
                        <img src="<%= detail.thumbnail %>" class="w-full h-full object-cover">
                    </div>
                    <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-primary rounded-full flex items-center justify-center text-white shadow-xl border-4 border-white">
                        <div class="text-center">
                            <span class="block text-[10px] font-black uppercase opacity-80 leading-none">Type</span>
                            <span class="text-lg font-black leading-none"><%= detail.info.jenis_komik %></span>
                        </div>
                    </div>
                </div>

                <div class="bg-white rounded-3xl border border-slate-100 p-6 shadow-sm">
                    <h3 class="text-lg font-black text-secondary mb-4 flex items-center gap-2">
                        <i class="ph-bold ph-info text-primary"></i> Detail Informasi
                    </h3>
                    <div class="space-y-4">
                        <% Object.entries(detail.info).forEach(([key, val]) => { %>
                            <div>
                                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block"><%= key.replace(/_/g, ' ') %></span>
                                <p class="text-sm font-bold text-secondary mt-0.5"><%= val %></p>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>

            <!-- Content: Title, Synopsis, Chapters -->
            <div class="lg:col-span-8">
                <div class="mb-8">
                    <h1 class="text-3xl md:text-5xl font-black text-secondary mb-3 leading-tight"><%= detail.title %></h1>
                    <p class="text-lg font-bold text-slate-400 mb-6"><%= detail.indo_title %></p>
                    
                    <div class="flex flex-wrap gap-2 mb-8">
                        <% detail.genres.forEach(genre => { %>
                            <span class="px-4 py-2 bg-slate-100 hover:bg-primary/10 hover:text-primary transition-all text-slate-600 rounded-xl text-xs font-bold cursor-default">
                                <%= genre %>
                            </span>
                        <% }) %>
                    </div>

                    <div class="relative group bg-white rounded-3xl border border-slate-100 p-8 shadow-sm">
                        <h2 class="text-xl font-black text-secondary mb-4">Sinopsis</h2>
                        <p class="text-slate-500 leading-relaxed text-sm font-medium">
                            <%= detail.description %>
                        </p>
                    </div>
                </div>

                <!-- Chapter List Header -->
                <div class="mb-6">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 mb-6">
                        <h2 class="text-2xl font-black text-secondary flex items-center gap-3">
                            <span>Daftar Chapter</span>
                            <span class="text-sm font-bold text-slate-400 bg-slate-100 px-3 py-1 rounded-lg"><%= detail.chapters.length %> Chapters</span>
                        </h2>
                        
                        <!-- Search/Go to Chapter Input -->
                        <div class="relative max-w-xs w-full">
                            <input 
                                type="text" 
                                id="chapter-search" 
                                placeholder="Cari chapter... (Contoh: 10)" 
                                class="w-full pl-10 pr-4 py-2 bg-slate-100 border-none rounded-xl text-sm font-bold text-secondary focus:ring-2 focus:ring-primary/20 transition-all"
                                onkeyup="filterChapters()"
                            >
                            <i class="ph-bold ph-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
                        </div>
                    </div>
                    
                    <!-- Chapter List Container -->
                    <div id="chapter-list" class="grid grid-cols-1 sm:grid-cols-2 gap-3 max-h-[600px] overflow-y-auto pr-2 custom-scrollbar">
                        <% detail.chapters.forEach(chapter => { %>
                            <div 
                                hx-get="/manga/read?url=<%= encodeURIComponent(chapter.originalLink) %>&mangaUrl=<%= encodeURIComponent(originalUrl) %>" 
                                hx-target="#main-content" 
                                hx-push-url="true" 
                                class="chapter-item group flex items-center justify-between p-4 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 hover:shadow-md transition-all cursor-pointer"
                                data-title="<%= chapter.title.toLowerCase() %>"
                            >
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-secondary group-hover:text-primary transition-colors"><%= chapter.title %></span>
                                    <span class="text-[10px] font-bold text-slate-400 uppercase mt-1"><%= chapter.date %></span>
                                </div>
                                <div class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400 group-hover:bg-primary group-hover:text-white transition-all">
                                    <i class="ph-bold ph-book-open"></i>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function filterChapters() {
        const input = document.getElementById('chapter-search');
        const filter = input.value.toLowerCase();
        const items = document.getElementsByClassName('chapter-item');

        for (let i = 0; i < items.length; i++) {
            const title = items[i].getAttribute('data-title');
            if (title.includes(filter)) {
                items[i].style.display = "";
            } else {
                items[i].style.display = "none";
            }
        }
    }
</script>