<title><%= title %></title>
<div class="max-w-3xl mx-auto py-16 px-4 fade-in">
    <div class="mb-8">
        <button 
            hx-get="/category" 
            hx-target="#main-content" 
            hx-push-url="true"
            class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-all group"
        >
            <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 group-hover:border-primary/30 group-hover:bg-primary/5">
                <i class="ph-bold ph-arrow-left"></i>
            </div>
            Kembali ke Kategori
        </button>
    </div>

    <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-slate-900/10 text-slate-900 mb-6 shadow-inner relative">
            <div class="absolute inset-0 bg-slate-900/5 blur-xl rounded-full"></div>
            <i class="ph-bold ph-tiktok-logo text-4xl relative z-10"></i>
        </div>
        <h1 class="text-4xl font-black text-secondary tracking-tight">TikTok Downloader</h1>
        <p class="text-slate-500 mt-3 text-lg">Download Video TikTok Tanpa Watermark (SnapTik Engine).</p>
    </div>

    <div class="bg-white p-2 rounded-[2.5rem] shadow-2xl shadow-slate-200/50 border border-slate-100 overflow-hidden relative">
        <div class="p-8">
            <div class="space-y-4">
                <div class="group">
                    <label for="url" class="block text-sm font-bold text-slate-700 mb-2 ml-1">TikTok Link</label>
                    <div class="relative">
                        <i class="ph-bold ph-link absolute left-5 top-1/2 -translate-y-1/2 text-slate-400 text-xl group-focus-within:text-primary transition-colors"></i>
                        <input 
                            type="url" 
                            id="tiktok-url" 
                            placeholder="https://www.tiktok.com/@user/video/..." 
                            class="w-full pl-14 pr-6 py-5 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:bg-white focus:border-primary focus:ring-4 focus:ring-primary/10 outline-none transition-all font-medium"
                            required
                        >
                    </div>
                </div>

                <button onclick="downloadTiktok()" id="tiktok-btn" class="w-full py-5 bg-secondary hover:bg-slate-800 text-white font-black rounded-2xl flex items-center justify-center gap-3 transition-all hover:shadow-xl active:scale-[0.98] btn-hover-effect">
                    <i class="ph-bold ph-download-simple text-xl"></i>
                    Ambil Video
                </button>
            </div>

            <div id="loading" class="hidden mt-10 text-center py-12">
                <div class="flex flex-col items-center justify-center space-y-6">
                    <div class="relative">
                        <div class="w-20 h-20 border-4 border-slate-100 rounded-full"></div>
                        <div class="absolute inset-0 w-20 h-20 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
                        <div class="absolute inset-0 flex items-center justify-center">
                            <i class="ph-fill ph-tiktok-logo text-primary text-2xl animate-pulse"></i>
                        </div>
                    </div>
                    <p class="text-sm font-black text-slate-800 tracking-widest uppercase">Menganalisis Link...</p>
                </div>
            </div>

            <div id="result-container" class="mt-8"></div>
        </div>
    </div>
</div>

<script>
    async function downloadTiktok() {
        const url = document.getElementById('tiktok-url').value;
        const resultContainer = document.getElementById('result-container');
        const loading = document.getElementById('loading');
        const btn = document.getElementById('tiktok-btn');

        if (!url) return alert('Masukkan URL TikTok dulu!');

        resultContainer.innerHTML = '';
        loading.classList.remove('hidden');
        btn.disabled = true;

        try {
            const res = await fetch('https://puruboy-api.vercel.app/api/downloader/snaptik', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url })
            });
            const data = await res.json();

            if (!data.success) throw new Error('Gagal mengambil data TikTok.');

            const result = data.result;
            const info = result.video_info;
            const links = result.download_links.map(link => `
                <div class="flex items-center justify-between p-4 bg-white border border-slate-100 rounded-xl shadow-sm mb-3">
                    <span class="text-sm font-bold text-slate-700">${link.type}</span>
                    <a href="${link.url}" target="_blank" class="px-5 py-2.5 bg-primary hover:bg-indigo-700 text-white text-sm font-bold rounded-xl transition-all flex items-center gap-2">
                        <i class="ph-bold ph-download-simple"></i>
                        Download
                    </a>
                </div>
            `).join('');

            resultContainer.innerHTML = `
                <div class="animation-fade-in space-y-6">
                    <div class="flex items-start gap-4 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <img src="${info.thumbnail}" class="w-24 h-32 object-cover rounded-xl shadow-md shrink-0">
                        <div class="space-y-1">
                            <p class="text-xs font-black text-primary uppercase tracking-widest">@${info.author}</p>
                            <p class="text-sm text-slate-700 font-semibold leading-snug line-clamp-3">${info.title}</p>
                        </div>
                    </div>
                    <div class="space-y-3">
                        <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest ml-1">Download Links</h4>
                        ${links}
                    </div>
                </div>
            `;
        } catch (err) {
            resultContainer.innerHTML = `<div class="p-4 text-sm text-red-800 rounded-lg bg-red-50 border border-red-200">❌ Error: ${err.message}</div>`;
        } finally {
            loading.classList.add('hidden');
            btn.disabled = false;
        }
    }
</script>
