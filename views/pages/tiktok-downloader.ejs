<title><%= title %></title>
<div class="max-w-2xl mx-auto py-8 sm:py-12 md:py-16 px-4 sm:px-6 fade-in flex-grow">
    <!-- Back Button -->
    <div class="mb-6 sm:mb-8">
        <button hx-get="/category" hx-target="#main-content" hx-push-url="true"
            class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 dark:text-slate-400 hover:text-primary transition-all group">
            <div class="w-8 h-8 flex items-center justify-center rounded-xl bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 group-hover:border-primary/40 group-hover:bg-primary/5 shadow-sm transition-all">
                <i class="ph-bold ph-arrow-left text-sm"></i>
            </div>
            Kembali
        </button>
    </div>

    <!-- Page Header -->
    <div class="text-center mb-7 sm:mb-9">
        <div class="inline-flex items-center justify-center w-16 h-16 sm:w-20 sm:h-20 rounded-3xl bg-slate-900 dark:bg-slate-700 mb-4 sm:mb-5 shadow-xl shadow-slate-900/20">
            <i class="ph-bold ph-tiktok-logo text-white text-3xl sm:text-4xl"></i>
        </div>
        <h1 class="text-2xl sm:text-3xl font-black text-secondary dark:text-white tracking-tight">TikTok Downloader</h1>
        <p class="text-slate-500 dark:text-slate-400 mt-1.5 text-sm sm:text-base">Download Video TikTok Tanpa Watermark</p>
    </div>

    <!-- Input Card -->
    <div class="bg-white dark:bg-slate-800/60 rounded-3xl shadow-lg shadow-slate-200/40 dark:shadow-slate-900/40 border border-slate-100 dark:border-slate-700/50 p-5 sm:p-7 mb-4">
        <div class="space-y-4">
            <div>
                <label for="tiktok-url" class="block text-xs font-black text-slate-500 dark:text-slate-400 uppercase tracking-widest mb-2">Link TikTok</label>
                <div class="relative">
                    <i class="ph-bold ph-link absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-lg pointer-events-none"></i>
                    <input
                        type="url"
                        id="tiktok-url"
                        placeholder="https://www.tiktok.com/@user/video/..."
                        class="w-full pl-11 pr-4 py-3.5 sm:py-4 bg-slate-50 dark:bg-slate-700/60 border-2 border-transparent rounded-2xl input-focus font-medium text-sm text-slate-700 dark:text-slate-200 placeholder:text-slate-400 dark:placeholder:text-slate-500"
                    >
                </div>
            </div>
            <button onclick="downloadTiktok()" id="tiktok-btn"
                class="w-full py-3.5 sm:py-4 bg-slate-900 dark:bg-primary hover:bg-slate-700 dark:hover:opacity-90 text-white font-black rounded-2xl flex items-center justify-center gap-2.5 transition-all active:scale-[0.98] btn-hover-effect text-sm sm:text-base shadow-md shadow-slate-900/15">
                <i class="ph-bold ph-download-simple text-lg"></i>
                Ambil Video
            </button>
        </div>

        <!-- Loading -->
        <div id="loading" class="hidden mt-8 py-10 text-center">
            <div class="relative w-16 h-16 mx-auto mb-4">
                <div class="absolute inset-0 border-4 border-slate-100 dark:border-slate-700 rounded-full"></div>
                <div class="absolute inset-0 border-4 border-primary border-t-transparent rounded-full animate-spin"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <i class="ph-fill ph-tiktok-logo text-primary text-xl animate-pulse"></i>
                </div>
            </div>
            <p class="text-xs font-black text-slate-500 dark:text-slate-400 tracking-widest uppercase">Menganalisis Link...</p>
        </div>
    </div>

    <!-- Result Container -->
    <div id="result-container"></div>
</div>

<script>
    async function downloadTiktok() {
        const url = document.getElementById('tiktok-url').value.trim();
        const resultContainer = document.getElementById('result-container');
        const loading = document.getElementById('loading');
        const btn = document.getElementById('tiktok-btn');
        if (!url) { 
            document.getElementById('tiktok-url').classList.add('border-red-400');
            setTimeout(() => document.getElementById('tiktok-url').classList.remove('border-red-400'), 1500);
            return; 
        }
        resultContainer.innerHTML = '';
        loading.classList.remove('hidden');
        btn.disabled = true;
        btn.innerHTML = '<i class="ph-bold ph-spinner animate-spin text-lg"></i> Memproses...';
        try {
            const res = await fetch('https://puruboy-api.vercel.app/api/downloader/snaptik', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url })
            });
            const data = await res.json();
            if (!data.success) throw new Error('Gagal mengambil data TikTok.');
            const result = data.result;
            const info = result.video_info;
            const links = result.download_links.map((link, i) => `
                <div class="result-card flex flex-col sm:flex-row sm:items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-2xl gap-3" style="animation-delay:${i*0.07}s">
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded-xl bg-primary/10 dark:bg-primary/20 flex items-center justify-center shrink-0">
                            <i class="ph-bold ph-file-video text-primary text-sm"></i>
                        </div>
                        <span class="text-sm font-bold text-slate-700 dark:text-slate-200">${link.type}</span>
                    </div>
                    <a href="${link.url}" target="_blank"
                        class="w-full sm:w-auto px-5 py-2.5 bg-primary hover:bg-indigo-600 text-white text-sm font-bold rounded-xl transition-all flex items-center justify-center gap-2 active:scale-95 btn-hover-effect">
                        <i class="ph-bold ph-download-simple"></i> Download
                    </a>
                </div>
            `).join('');
            resultContainer.innerHTML = `
                <div class="bg-white dark:bg-slate-800/60 rounded-3xl border border-slate-100 dark:border-slate-700/50 shadow-lg shadow-slate-200/40 dark:shadow-slate-900/40 p-5 sm:p-6 animate-scale-in space-y-5">
                    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-4">
                        <img src="${info.thumbnail}" class="w-20 h-28 sm:w-24 sm:h-32 object-cover rounded-2xl shadow-md shrink-0">
                        <div class="text-center sm:text-left space-y-1.5">
                            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-primary/8 dark:bg-primary/15 text-primary text-[10px] font-black uppercase tracking-wider">
                                <i class="ph-bold ph-at"></i>${info.author}
                            </span>
                            <p class="text-sm text-slate-700 dark:text-slate-300 font-semibold leading-relaxed line-clamp-3">${info.title}</p>
                        </div>
                    </div>
                    <div class="border-t border-slate-100 dark:border-slate-700/50 pt-4 space-y-2.5">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">Pilihan Download</p>
                        ${links}
                    </div>
                </div>
            `;
        } catch (err) {
            resultContainer.innerHTML = `
                <div class="p-4 text-sm text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-500/10 rounded-2xl border border-red-100 dark:border-red-500/20 font-medium flex items-center gap-3 animate-scale-in">
                    <i class="ph-bold ph-warning-circle text-xl shrink-0"></i> ${err.message}
                </div>`;
        } finally {
            loading.classList.add('hidden');
            btn.disabled = false;
            btn.innerHTML = '<i class="ph-bold ph-download-simple text-lg"></i> Ambil Video';
        }
    }
    document.getElementById('tiktok-url').addEventListener('keydown', e => {
        if (e.key === 'Enter') downloadTiktok();
    });
</script>
