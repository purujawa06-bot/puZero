<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        
        <!-- Header -->
        <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <button hx-get="/manga" hx-target="#main-content" hx-push-url="true" class="flex items-center gap-2 text-slate-400 hover:text-primary transition-colors font-bold text-xs mb-4">
                    <i class="ph-bold ph-arrow-left"></i> Kembali
                </button>
                <h1 class="text-3xl font-extrabold text-secondary tracking-tight">
                    Manga <span class="text-primary">Terpopuler</span>
                </h1>
                <p class="text-slate-500 text-sm font-medium mt-1">Judul yang paling banyak dibaca oleh pengguna PuZero.</p>
            </div>

            <!-- Simple Pagination -->
            <div class="flex items-center gap-2">
                <% if (pageNumber > 1) { %>
                    <button hx-get="/manga/popular?page=<%= pageNumber - 1 %>" hx-target="#main-content" hx-push-url="true" class="w-10 h-10 bg-white border border-slate-200 rounded-xl flex items-center justify-center text-slate-600 hover:border-primary hover:text-primary transition-all shadow-sm">
                        <i class="ph-bold ph-caret-left"></i>
                    </button>
                <% } %>
                <span class="px-4 py-2 bg-primary text-white font-black rounded-xl text-xs">Page <%= pageNumber %></span>
                <button hx-get="/manga/popular?page=<%= pageNumber + 1 %>" hx-target="#main-content" hx-push-url="true" class="w-10 h-10 bg-white border border-slate-200 rounded-xl flex items-center justify-center text-slate-600 hover:border-primary hover:text-primary transition-all shadow-sm">
                    <i class="ph-bold ph-caret-right"></i>
                </button>
            </div>
        </div>

        <!-- Popular Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% mangaList.forEach((manga, index) => { %>
                <% 
                   const urlParams = new URLSearchParams(manga.link.split('?')[1]);
                   const originalUrl = urlParams.get('url');
                %>
                <div hx-get="/manga/detail?url=<%= encodeURIComponent(originalUrl) %>" hx-target="#main-content" hx-push-url="true" class="bg-white p-4 rounded-[2rem] border border-slate-100 flex gap-5 items-center group cursor-pointer hover:shadow-xl transition-all hw-accelerate">
                    <div class="relative w-24 h-32 rounded-2xl overflow-hidden shrink-0 shadow-lg">
                        <img src="<%= manga.thumbnail %>" loading="lazy" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        <div class="absolute top-0 left-0 w-8 h-8 bg-primary text-white flex items-center justify-center font-black text-xs rounded-br-2xl border-b-2 border-r-2 border-white/20">
                            <%= (pageNumber - 1) * 10 + (index + 1) %>
                        </div>
                    </div>
                    <div class="overflow-hidden flex-grow">
                        <div class="flex items-center gap-2 mb-1">
                            <span class="px-2 py-0.5 bg-slate-100 text-slate-400 text-[8px] font-black rounded uppercase"><%= manga.type %></span>
                            <span class="text-[9px] text-primary font-bold uppercase"><%= manga.update_info %></span>
                        </div>
                        <h3 class="text-sm font-bold text-secondary line-clamp-1 group-hover:text-primary transition-colors"><%= manga.title %></h3>
                        <p class="text-[10px] text-slate-400 font-medium mt-2 line-clamp-2 leading-relaxed"><%= manga.description %></p>
                    </div>
                </div>
            <% }) %>
        </div>

    </div>
</div>