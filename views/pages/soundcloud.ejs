<title><%= title %></title>
<div class="max-w-4xl mx-auto py-16 px-4 fade-in">
    <div class="mb-8">
        <button 
            hx-get="/category" 
            hx-target="#main-content" 
            hx-push-url="true"
            class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-all group"
        >
            <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 group-hover:border-primary/30 group-hover:bg-primary/5">
                <i class="ph-bold ph-arrow-left"></i>
            </div>
            Kembali ke Kategori
        </button>
    </div>

    <div class="text-center mb-12">
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-3xl bg-orange-500/10 text-orange-500 mb-6 shadow-inner relative">
            <div class="absolute inset-0 bg-orange-500/20 blur-xl rounded-full animate-pulse"></div>
            <i class="ph-bold ph-soundcloud-logo text-4xl relative z-10"></i>
        </div>
        <h1 class="text-4xl font-black text-secondary tracking-tight">SoundCloud Downloader</h1>
        <p class="text-slate-500 mt-3 text-lg">Cari dan unduh musik dari SoundCloud dengan mudah.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Search Section -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
            <h3 class="text-lg font-black text-secondary mb-6 flex items-center gap-2">
                <i class="ph-bold ph-magnifying-glass text-orange-500"></i>
                Cari Musik
            </h3>
            <div class="space-y-4">
                <div class="relative group">
                    <input 
                        type="text" 
                        id="sc-search-query" 
                        placeholder="Ketik judul lagu atau artis..." 
                        class="w-full pl-6 pr-6 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:bg-white focus:border-orange-500 outline-none transition-all font-medium"
                        onkeydown="if(event.keyCode == 13) searchSC()"
                    >
                </div>
                <button onclick="searchSC()" id="sc-search-btn" class="w-full py-4 bg-orange-500 hover:bg-orange-600 text-white font-black rounded-2xl transition-all active:scale-95 shadow-lg shadow-orange-500/20">
                    Cari Sekarang
                </button>
            </div>
        </div>

        <!-- Download Section -->
        <div class="bg-white p-8 rounded-[2.5rem] shadow-xl border border-slate-100">
            <h3 class="text-lg font-black text-secondary mb-6 flex items-center gap-2">
                <i class="ph-bold ph-link text-orange-500"></i>
                Link Langsung
            </h3>
            <div class="space-y-4">
                <div class="relative group">
                    <input 
                        type="url" 
                        id="sc-url" 
                        placeholder="Paste SoundCloud link di sini..." 
                        class="w-full pl-6 pr-6 py-4 bg-slate-50 border-2 border-slate-100 rounded-2xl focus:bg-white focus:border-orange-500 outline-none transition-all font-medium"
                    >
                </div>
                <button onclick="downloadSC()" id="sc-dl-btn" class="w-full py-4 bg-secondary hover:bg-slate-800 text-white font-black rounded-2xl transition-all active:scale-95 shadow-lg shadow-slate-200">
                    Download Musik
                </button>
            </div>
        </div>
    </div>

    <!-- Loading -->
    <div id="sc-loading" class="hidden mt-12 text-center py-10">
        <div class="flex flex-col items-center gap-4">
            <div class="w-12 h-12 border-4 border-orange-200 border-t-orange-500 rounded-full animate-spin"></div>
            <p class="text-sm font-bold text-slate-400 animate-pulse">MENGHUBUNGI SERVER...</p>
        </div>
    </div>

    <!-- Results -->
    <div id="sc-results" class="mt-12 grid grid-cols-1 gap-4"></div>
</div>

<script>
    const resultDiv = document.getElementById('sc-results');
    const loading = document.getElementById('sc-loading');

    async function searchSC() {
        const query = document.getElementById('sc-search-query').value;
        if (!query) return alert('Masukkan kata kunci!');

        resultDiv.innerHTML = '';
        loading.classList.remove('hidden');

        try {
            const res = await fetch(`https://www.puruboy.kozow.com/api/search/soundcloud?q=${encodeURIComponent(query)}&limit=10`);
            const data = await res.json();

            if (!data.success) throw new Error('Pencarian gagal.');

            resultDiv.innerHTML = data.result.map(track => `
                <div class="bg-white p-4 rounded-2xl border border-slate-100 flex items-center justify-between group hover:border-orange-200 transition-all shadow-sm">
                    <div class="flex items-center gap-4 overflow-hidden">
                        <div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center text-orange-500 shrink-0">
                            <i class="ph-fill ph-music-notes text-2xl"></i>
                        </div>
                        <div class="overflow-hidden">
                            <h4 class="font-bold text-slate-800 truncate">${track.title}</h4>
                            <p class="text-xs text-slate-400 font-medium">${track.user} • ${track.duration} • ${track.plays} plays</p>
                        </div>
                    </div>
                    <button onclick="downloadSC('${track.url}')" class="px-4 py-2 bg-slate-100 group-hover:bg-orange-500 group-hover:text-white text-slate-600 rounded-xl text-xs font-bold transition-all shrink-0">
                        Ambil Link
                    </button>
                </div>
            `).join('');
        } catch (e) {
            resultDiv.innerHTML = `<div class="p-6 text-center text-red-500 font-bold bg-red-50 rounded-2xl border border-red-100">${e.message}</div>`;
        } finally {
            loading.classList.add('hidden');
        }
    }

    async function downloadSC(urlOverride) {
        const url = urlOverride || document.getElementById('sc-url').value;
        if (!url) return alert('Masukkan link SoundCloud!');

        resultDiv.innerHTML = '';
        loading.classList.remove('hidden');

        try {
            const res = await fetch('https://www.puruboy.kozow.com/api/downloader/soundcloud-v2', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url })
            });
            const data = await res.json();

            if (!data.success) throw new Error('Gagal mengambil detail lagu.');

            const track = data.result;
            resultDiv.innerHTML = `
                <div class="bg-white p-8 rounded-[2.5rem] border border-slate-100 shadow-2xl animate-fade-in">
                    <div class="flex flex-col md:flex-row gap-8 items-center">
                        <img src="${track.thumbnail}" class="w-48 h-48 rounded-3xl shadow-xl object-cover border-4 border-white">
                        <div class="flex-grow text-center md:text-left space-y-4">
                            <div>
                                <span class="px-3 py-1 bg-orange-500 text-white text-[10px] font-black rounded-full uppercase tracking-widest">SoundCloud Audio</span>
                                <h2 class="text-2xl font-black text-secondary mt-2 leading-tight">${track.title}</h2>
                                <p class="text-slate-400 font-bold text-sm uppercase tracking-wider">${track.author}</p>
                            </div>
                            <div class="flex flex-wrap gap-2 justify-center md:justify-start">
                                <a href="${track.url}" target="_blank" class="px-8 py-4 bg-orange-500 text-white rounded-2xl font-black flex items-center gap-3 hover:bg-orange-600 transition-all shadow-lg shadow-orange-500/20">
                                    <i class="ph-bold ph-download-simple"></i>
                                    Download MP3
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        } catch (e) {
            resultDiv.innerHTML = `<div class="p-6 text-center text-red-500 font-bold bg-red-50 rounded-2xl border border-red-100">${e.message}</div>`;
        } finally {
            loading.classList.add('hidden');
        }
    }
</script>
