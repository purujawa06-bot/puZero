<div class="w-full h-[100dvh] flex flex-col fade-in relative overflow-hidden">
    
    <!-- Top Header -->
    <div class="flex items-center justify-between px-4 sm:px-6 py-4 bg-slate-900/90 backdrop-blur-md sticky top-0 z-10 border-b border-slate-800 shadow-sm shrink-0">
        <div class="flex items-center gap-3 md:gap-4">
            <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-gradient-to-tr from-primary to-accent text-white shadow-lg shadow-primary/20">
                <i class="ph-fill ph-sparkle text-xl"></i>
            </div>
            <div>
                <h1 class="text-lg md:text-xl font-black text-white tracking-tight">Puzero AI</h1>
                <div class="flex items-center gap-1.5 mt-0.5">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Gemini V2 • Online</span>
                </div>
            </div>
        </div>

        <button 
            onclick="resetChat()" 
            class="px-3 md:px-4 py-2 bg-slate-800 border border-slate-700 text-slate-300 rounded-xl text-xs font-bold hover:border-primary hover:text-primary transition-all flex items-center gap-2 active:scale-95 shadow-sm"
        >
            <i class="ph-bold ph-plus"></i> <span class="hidden sm:inline">New Chat</span>
        </button>
    </div>

    <!-- Chat Area -->
    <div id="chat-window" class="flex-grow overflow-y-auto px-4 sm:px-6 py-6 space-y-6 custom-scrollbar pb-32">
        <div id="welcome" class="text-center py-12 md:py-20 max-w-lg mx-auto">
            <div class="w-16 h-16 md:w-20 md:h-20 bg-gradient-to-tr from-primary/20 to-accent/20 text-primary rounded-3xl mx-auto flex items-center justify-center mb-6 border border-slate-800 shadow-sm">
                <i class="ph-fill ph-brain text-3xl md:text-4xl"></i>
            </div>
            <h2 class="text-2xl md:text-3xl font-black text-white tracking-tight">Apa yang bisa saya bantu?</h2>
            <p class="text-slate-400 text-sm md:text-base mt-3 leading-relaxed">Tanyakan apapun, mulai dari coding, penulisan kreatif, hingga ringkasan data kompleks.</p>
        </div>
        
        <div id="chat-messages" class="flex flex-col space-y-6"></div>
        
        <div id="chat-loading" class="hidden mb-4">
            <div class="flex items-start gap-3">
                <div class="w-8 h-8 bg-slate-800 rounded-xl animate-pulse flex items-center justify-center shrink-0">
                    <i class="ph-bold ph-lightning text-slate-400"></i>
                </div>
                <div class="bg-slate-900 border border-slate-800 p-4 rounded-2xl rounded-tl-none w-24 shadow-sm">
                    <div class="flex gap-1.5 justify-center">
                        <span class="w-2 h-2 bg-primary/40 rounded-full animate-bounce" style="animation-delay: 0s"></span>
                        <span class="w-2 h-2 bg-primary/60 rounded-full animate-bounce" style="animation-delay: 0.1s"></span>
                        <span class="w-2 h-2 bg-primary/80 rounded-full animate-bounce" style="animation-delay: 0.2s"></span>
                    </div>
                </div>
            </div>
        </div>
        <div id="scroll-anchor" class="h-4 w-full"></div>
    </div>

    <!-- Input Area -->
    <div class="absolute bottom-0 left-0 w-full p-4 bg-gradient-to-t from-slate-950 via-slate-950 to-transparent shrink-0">
        <div class="max-w-3xl mx-auto">
            <div id="reply-container" class="hidden bg-slate-900 border border-slate-800 border-b-0 rounded-t-2xl p-3 flex items-center justify-between shadow-sm">
                <div class="flex items-center gap-3 overflow-hidden">
                    <i class="ph-bold ph-arrow-u-up-left text-primary shrink-0"></i>
                    <p id="reply-text" class="text-xs text-slate-400 italic truncate font-medium"></p>
                </div>
                <button onclick="cancelReply()" class="text-slate-500 hover:text-red-500 transition-colors shrink-0">
                    <i class="ph-bold ph-x-circle text-lg"></i>
                </button>
            </div>

            <div class="bg-slate-900/80 backdrop-blur-xl rounded-3xl shadow-2xl border border-white/5 p-2 transition-all focus-within:border-primary/40 focus-within:ring-1 focus-within:ring-primary/20">
                <div class="flex flex-col gap-2">
                    <details class="group px-2">
                        <summary class="list-none cursor-pointer flex items-center gap-1.5 text-[10px] font-black text-slate-500 uppercase tracking-widest hover:text-primary transition-colors select-none">
                            <i class="ph-bold ph-gear text-sm transition-transform group-open:rotate-90"></i> Custom Instructions
                        </summary>
                        <textarea id="system-prompt" class="w-full mt-2 bg-slate-800/50 border border-white/5 rounded-2xl p-3 text-xs md:text-sm text-slate-300 focus:outline-none focus:border-primary/50 transition-colors" rows="2" placeholder="Contoh: Jawab dalam bahasa gaul..."></textarea>
                    </details>

                    <div class="flex items-end gap-2 px-2 pb-1">
                        <textarea 
                            id="prompt-textarea"
                            class="w-full bg-transparent border-none focus:ring-0 text-slate-200 text-base md:text-sm py-3 resize-none max-h-48 overflow-y-auto custom-scrollbar placeholder:text-slate-500" 
                            rows="1" 
                            placeholder="Tanya apa saja..."
                            oninput="this.style.height = ''; this.style.height = Math.min(this.scrollHeight, 180) + 'px'"
                            onkeydown="handleKeyDown(event)"
                        ></textarea>
                        
                        <button id="send-btn" onclick="sendMessage()" class="w-10 h-10 bg-white text-slate-950 rounded-full flex items-center justify-center hover:bg-slate-200 transition-all shadow-lg active:scale-90 shrink-0 mb-1 disabled:opacity-50 disabled:scale-100" disabled>
                            <i class="ph-fill ph-arrow-up text-xl"></i>
                        </button>
                    </div>
                </div>
            </div>
            <p class="text-[10px] text-center text-slate-500 mt-3 font-medium opacity-60">Puzero AI Gemini V2 • Menghargai privasi dan kreativitas.</p>
        </div>
    </div>
</div>

<script>
    (function() {
        const escapeHtml = (u) => (u || "").toString().replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#039;");

        const chatMessages = document.getElementById('chat-messages');
        const systemInput = document.getElementById('system-prompt');
        const promptInput = document.getElementById('prompt-textarea');
        const welcomeDiv = document.getElementById('welcome');
        const scrollAnchor = document.getElementById('scroll-anchor');
        const loadingDiv = document.getElementById('chat-loading');
        const replyText = document.getElementById('reply-text');
        const replyContainer = document.getElementById('reply-container');
        const sendBtn = document.getElementById('send-btn');

        let currentReply = "";

        // UI Helpers
        const isMobile = () => /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent) || window.innerWidth < 768;

        promptInput.addEventListener('input', () => {
            sendBtn.disabled = !promptInput.value.trim();
        });

        window.handleKeyDown = function(event) {
            if (event.keyCode === 13 && !event.shiftKey) {
                if (!isMobile()) {
                    event.preventDefault();
                    sendMessage();
                }
                // Di mobile, biarkan default (baris baru)
            }
        };

        const getLocalState = () => {
            return {
                history: JSON.parse(localStorage.getItem('puzero_chat_history') || '[]'),
                system: localStorage.getItem('puzero_system_prompt') || "Kamu adalah AI asisten dari PuZero yang ramah dan membantu.",
                uid: localStorage.getItem('puzero_user_id') || ('user-' + Math.random().toString(36).substring(2, 15))
            };
        };

        const saveLocalState = (data) => {
            if (data.history) localStorage.setItem('puzero_chat_history', JSON.stringify(data.history.slice(-30))); // Simpan lebih banyak untuk diproses
            if (data.system) localStorage.setItem('puzero_system_prompt', data.system);
            if (data.uid) localStorage.setItem('puzero_user_id', data.uid);
        };

        const state = getLocalState();
        systemInput.value = state.system;
        
        const chatWindow = document.getElementById('chat-window');

        // Scroll ulang jika ada gambar yang baru dimuat (mencegah scroll terhenti di tengah)
        chatMessages.addEventListener('load', (e) => {
            if (e.target.tagName === 'IMG') scrollToBottom(false, false);
        }, true);

        const scrollToBottom = (instant = false, force = false) => {
            // Threshold ditingkatkan ke 500px agar pesan panjang tidak menghentikan scroll otomatis
            const isNearBottom = chatWindow.scrollHeight - chatWindow.scrollTop - chatWindow.clientHeight < 500;
            
            if (isNearBottom || instant || force) {
                setTimeout(() => {
                    chatWindow.scrollTo({
                        top: chatWindow.scrollHeight,
                        behavior: instant ? 'auto' : 'smooth'
                    });
                }, 50); // Delay lebih cepat untuk respon yang lebih instan
            }
        };

        window.setReply = function(text) {
            currentReply = text;
            replyText.innerText = text;
            replyContainer.classList.remove('hidden');
            promptInput.focus();
        };

        window.cancelReply = function() {
            currentReply = "";
            replyContainer.classList.add('hidden');
        };

        window.resetChat = function() {
            if(confirm('Mulai chat baru? Riwayat chat ini akan dihapus.')) {
                const newUid = 'user-' + Math.random().toString(36).substring(2, 15);
                saveLocalState({ history: [], uid: newUid });
                chatMessages.innerHTML = '';
                welcomeDiv.classList.remove('hidden');
                cancelReply();
            }
        };

        window.sendMessage = async function() {
            const prompt = promptInput.value.trim();
            if(!prompt) return;

            const currentState = getLocalState();
            welcomeDiv.classList.add('hidden');
            const safePrompt = escapeHtml(prompt);
            const safeReplyPreview = currentReply ? escapeHtml(currentReply).substring(0, 50) + "..." : "";
            
            // Tambahkan pesan user ke UI
            chatMessages.insertAdjacentHTML('beforeend', `
                <div class="flex flex-col items-end space-y-2 group animate-fade-in w-full mb-2">
                    <div class="max-w-[85%] bg-slate-800 text-slate-100 p-3 md:p-4 rounded-3xl rounded-tr-sm border border-white/5 shadow-sm">
                        ${currentReply ? `<div class="text-[10px] opacity-50 border-l-2 border-primary/50 pl-2 mb-2 italic truncate">Replying to: ${safeReplyPreview}</div>` : ''}
                        <p class="text-sm md:text-base whitespace-pre-wrap break-words leading-relaxed">${safePrompt}</p>
                    </div>
                </div>
            `);

            // Membangun Konteks Memori (20 pesan terakhir = 10 percakapan)
            const memoryContext = currentState.history.slice(-20).map(m => {
                const role = m.role === 'user' ? 'User' : 'Assistant';
                return `${role}: ${m.text}`;
            }).join('\n');

            const systemInstruction = systemInput.value ? `Instructions: ${systemInput.value}\n\n` : '';
            const finalPrompt = `${systemInstruction}${memoryContext}\nUser: ${currentReply ? `[Replying to: ${currentReply}] ` : ''}${prompt}\nAssistant:`;

            promptInput.value = '';
            promptInput.style.height = 'auto';
            sendBtn.disabled = true;
            const replyToSnapshot = currentReply;
            cancelReply();
            scrollToBottom(false, true); // Force scroll ke pesan user yang baru masuk
            loadingDiv.classList.remove('hidden');

            try {
                const res = await fetch('https://puruboy-api.vercel.app/api/ai/gemini-v2', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        prompt: finalPrompt
                    })
                });

                const data = await res.json();
                if (!data.success) throw new Error("Gagal mendapatkan respon");

                const aiText = data.result.answer;
                const aiHtml = `
                    <div class="flex flex-col items-start space-y-2 group w-full mb-4 animate-fade-in">
                        <div class="flex items-center gap-2.5 ml-1">
                            <div class="w-7 h-7 bg-white text-slate-950 rounded-full flex items-center justify-center shadow-sm">
                                <i class="ph-fill ph-sparkle text-sm"></i>
                            </div>
                            <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Puzero AI</span>
                        </div>
                        <div class="max-w-[95%] md:max-w-[85%] bg-transparent p-1 md:p-2 ml-8">
                            <div class="prose prose-sm md:prose-base prose-slate dark:prose-invert max-w-none text-slate-200 leading-relaxed overflow-x-auto break-words ai-content">${marked.parse(aiText)}</div>
                        </div>
                        <div class="flex items-center gap-4 ml-10 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button data-reply="${encodeURIComponent(aiText.replace(/\n/g, ' '))}" onclick="setReply(decodeURIComponent(this.getAttribute('data-reply')))" class="text-[10px] text-slate-500 font-bold uppercase tracking-wider flex items-center gap-1 hover:text-white transition-colors">
                                <i class="ph-bold ph-arrow-u-up-left"></i> Reply
                            </button>
                            <button onclick="navigator.clipboard.writeText(\`${aiText.replace(/`/g, '\\`')}\`)" class="text-[10px] text-slate-500 font-bold uppercase tracking-wider flex items-center gap-1 hover:text-white transition-colors">
                                <i class="ph-bold ph-copy"></i> Copy
                            </button>
                        </div>
                    </div>
                `;
                chatMessages.insertAdjacentHTML('beforeend', aiHtml);
                scrollToBottom(false, false);
                
                const updatedHistory = currentState.history;
                updatedHistory.push({ role: 'user', text: prompt, replyTo: replyToSnapshot });
                updatedHistory.push({ role: 'model', text: aiText });
                saveLocalState({ history: updatedHistory, system: systemInput.value });
                
            } catch (err) {
                chatMessages.insertAdjacentHTML('beforeend', `<div class="p-3 text-red-400 text-xs md:text-sm bg-red-900/20 rounded-xl max-w-[80%] border border-red-800/50">❌ Error: ${err.message}</div>`);
            } finally {
                loadingDiv.classList.add('hidden');
                scrollToBottom();
            }
        };

        function renderHistory() {
            if (typeof marked === 'undefined') {
                setTimeout(renderHistory, 50);
                return;
            }
            const hist = getLocalState().history;
            if (hist.length > 0) {
                welcomeDiv.classList.add('hidden');
                hist.forEach(msg => {
                    let html = '';
                    if (msg.role === 'user') {
                        const safeReplyPreview = msg.replyTo ? escapeHtml(msg.replyTo).substring(0, 50) + "..." : "";
                        html = `
                            <div class="flex flex-col items-end space-y-2 group w-full mb-4">
                                <div class="max-w-[85%] bg-slate-800 text-slate-100 p-3 md:p-4 rounded-3xl rounded-tr-sm border border-white/5 shadow-sm">
                                    ${msg.replyTo ? `<div class="text-[10px] opacity-50 border-l-2 border-primary/50 pl-2 mb-2 italic truncate">Replying to: ${safeReplyPreview}</div>` : ''}
                                    <p class="text-sm md:text-base whitespace-pre-wrap break-words leading-relaxed">${escapeHtml(msg.text)}</p>
                                </div>
                            </div>`;
                    } else {
                        html = `
                            <div class="flex flex-col items-start space-y-2 group w-full mb-6">
                                <div class="flex items-center gap-2.5 ml-1">
                                    <div class="w-7 h-7 bg-white text-slate-950 rounded-full flex items-center justify-center shadow-sm">
                                        <i class="ph-fill ph-sparkle text-sm"></i>
                                    </div>
                                    <span class="text-[11px] font-bold text-slate-400 uppercase tracking-wider">Puzero AI</span>
                                </div>
                                <div class="max-w-[95%] md:max-w-[85%] bg-transparent p-1 md:p-2 ml-8">
                                    <div class="prose prose-sm md:prose-base prose-slate dark:prose-invert max-w-none text-slate-200 leading-relaxed overflow-x-auto break-words ai-content">${marked.parse(msg.text)}</div>
                                </div>
                                <div class="flex items-center gap-4 ml-10 opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button data-reply="${encodeURIComponent(msg.text.replace(/\n/g, ' '))}" onclick="setReply(decodeURIComponent(this.getAttribute('data-reply')))" class="text-[10px] text-slate-500 font-bold uppercase tracking-wider flex items-center gap-1 hover:text-white transition-colors">
                                        <i class="ph-bold ph-arrow-u-up-left"></i> Reply
                                    </button>
                                    <button onclick="navigator.clipboard.writeText(\`${msg.text.replace(/`/g, '\\`').replace(/\$/g, '\\$')}\`)" class="text-[10px] text-slate-500 font-bold uppercase tracking-wider flex items-center gap-1 hover:text-white transition-colors">
                                        <i class="ph-bold ph-copy"></i> Copy
                                    </button>
                                </div>
                            </div>`;
                    }
                    chatMessages.insertAdjacentHTML('beforeend', html);
                });
                scrollToBottom(true);
            }
        }
        
        // Memastikan inisialisasi berjalan baik di HTMX maupun Direct Load
        if (document.readyState === 'complete') {
            renderHistory();
        } else {
            window.addEventListener('load', renderHistory);
        }
    })();
</script>