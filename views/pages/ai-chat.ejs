<title><%= title %></title>
<div class="flex flex-col bg-[#f8fafc] dark:bg-slate-950 fade-in relative" style="height: calc(100dvh - 56px);">

    <!-- Chat Header -->
    <div class="flex items-center justify-between px-4 sm:px-5 py-3.5 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md sticky top-0 z-10 border-b border-slate-100 dark:border-slate-800/60 shadow-sm shrink-0">
        <div class="flex items-center gap-3">
            <button hx-get="/category" hx-target="#main-content" hx-push-url="true"
                class="w-9 h-9 flex items-center justify-center rounded-xl bg-slate-50 dark:bg-slate-800 text-slate-600 dark:text-slate-400 hover:bg-primary hover:text-white transition-all border border-slate-100 dark:border-slate-700 active:scale-90">
                <i class="ph-bold ph-arrow-left text-base"></i>
            </button>
            <div class="flex items-center gap-2.5">
                <div class="w-9 h-9 bg-gradient-to-tr from-primary to-accent rounded-2xl flex items-center justify-center shadow-sm shadow-primary/20">
                    <i class="ph-bold ph-brain text-white text-base"></i>
                </div>
                <div>
                    <div class="text-sm font-black text-secondary dark:text-white leading-tight">Gemini 3 Flash</div>
                    <div class="flex items-center gap-1.5 mt-0.5">
                        <div class="relative flex h-1.5 w-1.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500"></span>
                        </div>
                        <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Online</span>
                    </div>
                </div>
            </div>
        </div>
        <button onclick="resetChat()"
            class="px-3 py-1.5 bg-slate-50 dark:bg-slate-800 border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-xl text-xs font-bold hover:border-primary/40 hover:text-primary transition-all flex items-center gap-1.5 active:scale-95">
            <i class="ph-bold ph-plus text-sm"></i>
            <span class="hidden sm:inline">New Chat</span>
        </button>
    </div>

    <!-- Chat Messages -->
    <div id="chat-window" class="flex-grow overflow-y-auto px-4 sm:px-5 py-5 space-y-4 custom-scrollbar" style="padding-bottom: 160px;">
        <div id="welcome" class="text-center py-10 sm:py-16 max-w-md mx-auto px-4">
            <div class="w-16 h-16 bg-gradient-to-tr from-primary/10 to-accent/10 rounded-3xl mx-auto flex items-center justify-center mb-4 border border-white dark:border-slate-700 shadow-sm">
                <i class="ph-fill ph-brain text-primary text-3xl"></i>
            </div>
            <h2 class="text-xl sm:text-2xl font-black text-secondary dark:text-white tracking-tight mb-2">Apa yang bisa saya bantu?</h2>
            <p class="text-slate-400 dark:text-slate-500 text-sm leading-relaxed">Tanyakan apapun — coding, penulisan kreatif, hingga ringkasan data kompleks.</p>
            <!-- Suggestion chips -->
            <div class="mt-6 flex flex-wrap gap-2 justify-center">
                <button onclick="setPrompt('Jelaskan cara kerja API dengan contoh')" class="px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-semibold text-slate-600 dark:text-slate-300 hover:border-primary/40 hover:text-primary transition-all active:scale-95">💡 Jelaskan API</button>
                <button onclick="setPrompt('Tulis email profesional untuk melamar kerja')" class="px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-semibold text-slate-600 dark:text-slate-300 hover:border-primary/40 hover:text-primary transition-all active:scale-95">✉️ Email Melamar</button>
                <button onclick="setPrompt('Bantu saya debug kode JavaScript ini')" class="px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-semibold text-slate-600 dark:text-slate-300 hover:border-primary/40 hover:text-primary transition-all active:scale-95">🐛 Debug Kode</button>
                <button onclick="setPrompt('Ringkas artikel berikut untuk saya')" class="px-3 py-1.5 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl text-xs font-semibold text-slate-600 dark:text-slate-300 hover:border-primary/40 hover:text-primary transition-all active:scale-95">📄 Ringkas Teks</button>
            </div>
        </div>
        <div id="chat-messages" class="flex flex-col space-y-4"></div>
        <div id="chat-loading" class="hidden">
            <div class="flex items-start gap-2.5">
                <div class="w-8 h-8 bg-gradient-to-tr from-primary to-accent rounded-2xl flex items-center justify-center shrink-0 shadow-sm shadow-primary/20">
                    <i class="ph-bold ph-lightning text-white text-xs"></i>
                </div>
                <div class="bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 px-4 py-3 rounded-2xl rounded-tl-sm shadow-sm">
                    <div class="flex gap-1.5">
                        <span class="w-2 h-2 bg-primary/40 rounded-full animate-bounce" style="animation-delay:0s"></span>
                        <span class="w-2 h-2 bg-primary/60 rounded-full animate-bounce" style="animation-delay:0.12s"></span>
                        <span class="w-2 h-2 bg-primary/80 rounded-full animate-bounce" style="animation-delay:0.24s"></span>
                    </div>
                </div>
            </div>
        </div>
        <div id="scroll-anchor" class="h-2 w-full"></div>
    </div>

    <!-- Input Area -->
    <div class="absolute bottom-0 left-0 w-full bg-gradient-to-t from-[#f8fafc] dark:from-slate-950 via-[#f8fafc]/95 dark:via-slate-950/95 to-transparent pt-6 pb-4 px-4 sm:px-5">
        <!-- Reply Preview -->
        <div id="reply-container" class="hidden bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 border-b-0 rounded-t-2xl px-4 py-2.5 flex items-center justify-between gap-3 shadow-sm">
            <div class="flex items-center gap-2.5 overflow-hidden min-w-0">
                <div class="w-1 h-8 bg-primary rounded-full shrink-0"></div>
                <p id="reply-text" class="text-xs text-slate-500 dark:text-slate-400 italic truncate font-medium"></p>
            </div>
            <button onclick="cancelReply()" class="text-slate-400 hover:text-red-500 transition-colors shrink-0">
                <i class="ph-bold ph-x text-base"></i>
            </button>
        </div>

        <!-- Main Input -->
        <div id="input-box" class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl shadow-slate-200/60 dark:shadow-slate-900/60 border border-slate-200 dark:border-slate-700 p-2.5 transition-all focus-within:border-primary/50 focus-within:shadow-primary/8">
            <!-- System Prompt (collapsible) -->
            <details class="group px-1.5 mb-1">
                <summary class="list-none cursor-pointer flex items-center gap-1.5 text-[9px] font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-colors select-none py-1">
                    <i class="ph-bold ph-gear text-sm group-open:rotate-90 transition-transform"></i>
                    Custom Instructions
                </summary>
                <textarea id="system-prompt"
                    class="w-full mt-1.5 bg-slate-50 dark:bg-slate-700/60 border border-slate-100 dark:border-slate-600 rounded-xl p-3 text-xs focus:outline-none focus:border-primary/30 transition-colors resize-none text-slate-600 dark:text-slate-300 placeholder:text-slate-400"
                    rows="2" placeholder="Contoh: Jawab dalam bahasa gaul..."></textarea>
            </details>

            <div class="flex items-end gap-2 px-1.5">
                <textarea
                    id="prompt-textarea"
                    class="w-full bg-transparent border-none focus:ring-0 text-slate-700 dark:text-slate-200 text-sm py-2 resize-none max-h-28 overflow-y-auto custom-scrollbar placeholder:text-slate-400 dark:placeholder:text-slate-500"
                    rows="1"
                    placeholder="Ketik pesan di sini..."
                    oninput="this.style.height=''; this.style.height=Math.min(this.scrollHeight,110)+'px'"
                    onkeydown="if(event.keyCode==13&&!event.shiftKey){event.preventDefault();sendMessage()}"
                ></textarea>
                <button onclick="sendMessage()"
                    class="w-9 h-9 sm:w-10 sm:h-10 bg-secondary dark:bg-primary text-white rounded-xl flex items-center justify-center hover:bg-primary transition-all shadow-md active:scale-90 shrink-0 mb-0.5 btn-hover-effect">
                    <i class="ph-bold ph-paper-plane-right text-base sm:text-lg"></i>
                </button>
            </div>
        </div>
        <p class="text-[9px] text-center text-slate-400 dark:text-slate-600 mt-1.5 font-medium">AI bisa membuat kesalahan. Verifikasi informasi penting.</p>
    </div>
</div>

<script>
(function() {
    const escapeHtml = (u) => (u||'').toString().replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
    const $ = id => document.getElementById(id);

    const chatMessages = $('chat-messages');
    const systemInput = $('system-prompt');
    const promptInput = $('prompt-textarea');
    const welcomeDiv = $('welcome');
    const scrollAnchor = $('scroll-anchor');
    const loadingDiv = $('chat-loading');
    const replyText = $('reply-text');
    const replyContainer = $('reply-container');
    const inputBox = $('input-box');

    let currentReply = '';

    const getLS = () => ({
        history: JSON.parse(localStorage.getItem('puzero_chat_history')||'[]'),
        system: localStorage.getItem('puzero_system_prompt')||'Kamu adalah AI asisten dari PuZero yang ramah dan membantu.',
        uid: localStorage.getItem('puzero_user_id')||('user-'+Math.random().toString(36).substring(2,15))
    });
    const saveLS = (d) => {
        if(d.history) localStorage.setItem('puzero_chat_history',JSON.stringify(d.history.slice(-20)));
        if(d.system) localStorage.setItem('puzero_system_prompt',d.system);
        if(d.uid) localStorage.setItem('puzero_user_id',d.uid);
    };

    const state = getLS();
    systemInput.value = state.system;

    const scrollToBottom = () => scrollAnchor.scrollIntoView({behavior:'smooth',block:'end'});

    window.setPrompt = (text) => { promptInput.value = text; promptInput.focus(); };
    window.setReply = (text) => {
        currentReply = text;
        replyText.innerText = text.substring(0,80)+'...';
        replyContainer.classList.remove('hidden');
        inputBox.classList.add('rounded-t-none');
        promptInput.focus();
    };
    window.cancelReply = () => {
        currentReply = '';
        replyContainer.classList.add('hidden');
        inputBox.classList.remove('rounded-t-none');
    };
    window.resetChat = () => {
        if(confirm('Mulai chat baru? Riwayat akan dihapus.')) {
            const uid = 'user-'+Math.random().toString(36).substring(2,15);
            saveLS({history:[],uid});
            chatMessages.innerHTML = '';
            welcomeDiv.classList.remove('hidden');
            cancelReply();
        }
    };

    window.sendMessage = async function() {
        const prompt = promptInput.value.trim();
        if(!prompt) return;
        const curState = getLS();
        welcomeDiv.classList.add('hidden');

        const safePrompt = escapeHtml(prompt);
        const replyPreview = currentReply ? escapeHtml(currentReply.substring(0,50))+'...' : '';
        chatMessages.insertAdjacentHTML('beforeend', `
            <div class="flex flex-col items-end gap-1 group w-full animate-slide-up">
                <div class="max-w-[88%] sm:max-w-[78%] bg-primary text-white px-4 py-3 chat-bubble-user shadow-sm">
                    ${currentReply ? `<div class="text-[10px] opacity-65 border-l-2 border-white/40 pl-2 mb-2 italic truncate">↩ ${replyPreview}</div>` : ''}
                    <p class="text-sm leading-relaxed whitespace-pre-wrap break-words">${safePrompt}</p>
                </div>
            </div>`);

        const finalPrompt = currentReply ? `[Replying to: ${currentReply}]\n\n${prompt}` : prompt;
        promptInput.value = ''; promptInput.style.height = 'auto';
        const replySnap = currentReply;
        cancelReply();
        scrollToBottom();
        loadingDiv.classList.remove('hidden');

        try {
            const res = await fetch('https://puruboy-api.vercel.app/api/ai/puruai', {
                method:'POST',
                headers:{'Content-Type':'application/json'},
                body: JSON.stringify({userid:curState.uid, prompt:finalPrompt, model:'puruboy-flash', system:systemInput.value})
            });
            const data = await res.json();
            if(!data.success) throw new Error('Gagal mendapatkan respon');
            const aiText = data.result[0].parts[0].text;
            chatMessages.insertAdjacentHTML('beforeend', `
                <div class="flex flex-col items-start gap-1 group w-full animate-slide-up">
                    <div class="max-w-[92%] sm:max-w-[82%] bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 px-4 py-4 chat-bubble-ai shadow-sm">
                        <div class="flex items-center gap-2 mb-2.5">
                            <div class="w-5 h-5 bg-gradient-to-tr from-primary to-accent rounded-lg flex items-center justify-center shrink-0">
                                <i class="ph-fill ph-lightning text-white text-[9px]"></i>
                            </div>
                            <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">PuZero AI</span>
                        </div>
                        <div class="prose prose-sm prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-200 leading-relaxed overflow-x-auto break-words ai-content">${marked.parse(aiText)}</div>
                    </div>
                    <button data-reply="${encodeURIComponent(aiText.replace(/\n/g,' '))}" onclick="setReply(decodeURIComponent(this.getAttribute('data-reply')))"
                        class="text-[9px] text-slate-400 opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity font-bold uppercase tracking-wider ml-2 flex items-center gap-1 active:scale-95">
                        <i class="ph-bold ph-arrow-u-up-left"></i> Reply
                    </button>
                </div>`);

            const hist = curState.history;
            hist.push({role:'user',text:prompt,replyTo:replySnap});
            hist.push({role:'model',text:aiText});
            saveLS({history:hist,system:systemInput.value});
        } catch(err) {
            chatMessages.insertAdjacentHTML('beforeend', `
                <div class="flex items-center gap-2.5 p-3.5 text-red-700 dark:text-red-400 bg-red-50 dark:bg-red-500/10 rounded-2xl max-w-[85%] border border-red-100 dark:border-red-500/20 text-sm font-medium animate-scale-in">
                    <i class="ph-bold ph-warning-circle text-lg shrink-0"></i> ${err.message}
                </div>`);
        } finally {
            loadingDiv.classList.add('hidden');
            scrollToBottom();
        }
    };

    function renderHistory() {
        const hist = getLS().history;
        if(hist.length > 0) {
            welcomeDiv.classList.add('hidden');
            hist.forEach(msg => {
                if(msg.role==='user') {
                    const rp = msg.replyTo ? escapeHtml(msg.replyTo.substring(0,50))+'...' : '';
                    chatMessages.insertAdjacentHTML('beforeend',`
                        <div class="flex flex-col items-end gap-1 w-full">
                            <div class="max-w-[88%] sm:max-w-[78%] bg-primary text-white px-4 py-3 chat-bubble-user shadow-sm">
                                ${msg.replyTo?`<div class="text-[10px] opacity-65 border-l-2 border-white/40 pl-2 mb-2 italic truncate">↩ ${rp}</div>`:''}
                                <p class="text-sm leading-relaxed whitespace-pre-wrap break-words">${escapeHtml(msg.text)}</p>
                            </div>
                        </div>`);
                } else {
                    chatMessages.insertAdjacentHTML('beforeend',`
                        <div class="flex flex-col items-start gap-1 group w-full">
                            <div class="max-w-[92%] sm:max-w-[82%] bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 px-4 py-4 chat-bubble-ai shadow-sm">
                                <div class="flex items-center gap-2 mb-2.5">
                                    <div class="w-5 h-5 bg-gradient-to-tr from-primary to-accent rounded-lg flex items-center justify-center shrink-0"><i class="ph-fill ph-lightning text-white text-[9px]"></i></div>
                                    <span class="text-[9px] font-black text-slate-400 uppercase tracking-widest">PuZero AI</span>
                                </div>
                                <div class="prose prose-sm prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-200 leading-relaxed overflow-x-auto break-words">${marked.parse(msg.text)}</div>
                            </div>
                            <button data-reply="${encodeURIComponent(msg.text.replace(/\n/g,' '))}" onclick="setReply(decodeURIComponent(this.getAttribute('data-reply')))"
                                class="text-[9px] text-slate-400 opacity-100 sm:opacity-0 group-hover:opacity-100 transition-opacity font-bold uppercase tracking-wider ml-2 flex items-center gap-1">
                                <i class="ph-bold ph-arrow-u-up-left"></i> Reply
                            </button>
                        </div>`);
                }
            });
            setTimeout(scrollToBottom,100);
        }
    }
    renderHistory();
})();
</script>

<style>
.prose pre { background-color: #0f172a !important; color: #f8fafc !important; border-radius: 0.875rem !important; padding: 1rem 1.25rem !important; overflow-x: auto; font-size: 0.8rem !important; }
.prose code { color: #db2777; background-color: #f1f5f9; padding: 0.1rem 0.35rem; border-radius: 0.3rem; font-size: 0.82em; }
.prose pre code { color: inherit; background-color: transparent; padding: 0; font-size: inherit; }
.dark .prose pre { background-color: #020617 !important; }
.dark .prose code { background-color: #1e293b; }
</style>
