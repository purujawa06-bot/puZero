<title><%= title %></title>
<div class="max-w-6xl mx-auto px-4 py-10 fade-in">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <button 
                hx-get="/anime" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="flex items-center gap-2 text-xs font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-all mb-2"
            >
                <i class="ph-bold ph-arrow-left"></i> Kembali ke Daftar
            </button>
            <h1 class="text-2xl md:text-3xl font-black text-secondary leading-tight"><%= stream.title %></h1>
        </div>
    </div>

    <!-- Video Player Container (Standard Browser Player) -->
    <div id="main-player-wrapper" class="bg-slate-900 aspect-video rounded-[2.5rem] overflow-hidden shadow-2xl relative mb-6 border-4 border-white">
        <div id="player-container" class="w-full h-full flex items-center justify-center relative bg-black">
            <div class="text-center p-10">
                <div class="w-20 h-20 bg-primary/20 text-primary rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="ph-fill ph-play text-4xl"></i>
                </div>
                <h3 class="text-white font-bold text-lg">Siap Memutar...</h3>
            </div>
        </div>
    </div>

    <!-- Navigation Buttons -->
    <div class="flex items-center justify-between gap-4 mb-10">
        <% if (stream.prevEps) { %>
            <button 
                hx-get="/anime/stream/<%= stream.prevEps %>"
                hx-target="#main-content"
                hx-push-url="true"
                class="flex-1 flex items-center justify-center gap-2 py-4 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm"
            >
                <i class="ph-bold ph-caret-left"></i> Sebelumnya
            </button>
        <% } %>

        <% if (stream.nextEps) { %>
            <button 
                hx-get="/anime/stream/<%= stream.nextEps %>"
                hx-target="#main-content"
                hx-push-url="true"
                class="flex-1 flex items-center justify-center gap-2 py-4 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm"
            >
                Berikutnya <i class="ph-bold ph-caret-right"></i>
            </button>
        <% } %>
    </div>

    <!-- Server Selector -->
    <div class="mb-12">
        <h3 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
            <i class="ph-bold ph-hard-drives text-primary"></i> Pilih Server
        </h3>
        <div class="flex flex-wrap gap-2">
            <% stream.servers.forEach((srv, idx) => { %>
                <button 
                    onclick="changeServer(this)"
                    data-post="<%= srv.post %>"
                    data-nume="<%= srv.nume %>"
                    data-type="<%= srv.type %>"
                    class="server-btn px-5 py-3 bg-white border border-slate-200 rounded-2xl text-xs font-bold text-slate-600 hover:border-primary hover:text-primary transition-all shadow-sm"
                >
                    <%= srv.name %>
                </button>
            <% }) %>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Download Links -->
        <div class="lg:col-span-2 space-y-8">
            <h3 class="text-xl font-black text-secondary flex items-center gap-2">
                <i class="ph-bold ph-download-simple text-primary"></i>
                Link Download
            </h3>

            <% stream.downloads.forEach(dl => { %>
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
                    <div class="bg-slate-50 px-6 py-3 border-b border-slate-100">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest"><%= dl.format %></span>
                    </div>
                    <div class="p-6 space-y-6">
                        <% dl.items.forEach(item => { %>
                            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-slate-50 pb-4 last:border-0 last:pb-0">
                                <div class="w-20 shrink-0">
                                    <span class="px-3 py-1 bg-secondary text-white text-[10px] font-black rounded-lg"><%= item.resolution %></span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <% item.links.forEach(l => { %>
                                        <a href="<%= l.link %>" target="_blank" class="px-3 py-1.5 bg-slate-100 hover:bg-primary hover:text-white rounded-lg text-[10px] font-bold text-slate-600 transition-all">
                                            <%= l.server %>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Episodes List -->
        <div class="space-y-6">
            <h3 class="text-xl font-black text-secondary flex items-center gap-2">
                <i class="ph-bold ph-squares-four text-primary"></i>
                Daftar Episode
            </h3>
            <div class="space-y-3 h-[600px] overflow-y-auto custom-scrollbar pr-2">
                <% stream.episodes.forEach(ep => { %>
                    <a 
                        hx-get="/anime/stream/<%= ep.slug %>"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="flex items-center gap-4 p-3 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 transition-all group cursor-pointer"
                    >
                        <div class="w-16 h-10 shrink-0 rounded-lg overflow-hidden bg-slate-100">
                            <img src="<%= ep.thumb %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform">
                        </div>
                        <div class="overflow-hidden">
                            <h4 class="text-xs font-bold text-slate-700 truncate group-hover:text-primary transition-colors"><%= ep.title %></h4>
                            <p class="text-[10px] text-slate-400 mt-0.5"><%= ep.date %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<script>
    async function changeServer(btn) {
        const post = btn.getAttribute('data-post');
        const nume = btn.getAttribute('data-nume');
        const type = btn.getAttribute('data-type');
        const container = document.getElementById('player-container');

        document.querySelectorAll('.server-btn').forEach(b => {
            b.classList.remove('bg-primary', 'text-white', 'border-primary');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.add('bg-primary', 'text-white', 'border-primary');

        container.innerHTML = `<div class="w-10 h-10 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>`;

        try {
            const res = await fetch('/anime/player', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post, nume, type })
            });
            const data = await res.json();
            
            if (data.type === 'enhanced') {
                const proxyUrl = '/stream?url=' + encodeURIComponent(data.src);
                container.innerHTML = `
                    <video class="w-full h-full" controls playsinline autoplay>
                        <source src="${proxyUrl}" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>
                `;
            } else {
                container.innerHTML = data.html;
            }
        } catch (e) {
            container.innerHTML = `<div class="text-red-500 text-xs font-bold">Gagal memuat player.</div>`;
        }
    }

    (function autoSelectServer() {
        const serverButtons = document.querySelectorAll('.server-btn');
        if (serverButtons.length === 0) return;
        let target = Array.from(serverButtons).find(btn => btn.innerText.includes('720p')) || serverButtons[0];
        if (target) changeServer(target);
    })();
</script>
