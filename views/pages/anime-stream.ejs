<title><%= title %></title>

<div class="max-w-6xl mx-auto px-4 py-10 fade-in">
    <!-- Header -->
    <div class="mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
            <button 
                hx-get="/anime" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="flex items-center gap-2 text-xs font-black text-slate-400 uppercase tracking-widest hover:text-primary transition-all mb-2 hw-accelerate"
            >
                <i class="ph-bold ph-arrow-left"></i> Kembali ke Daftar
            </button>
            <h1 class="text-2xl md:text-3xl font-black text-secondary leading-tight" id="stream-title"><%= stream.title %></h1>
        </div>
    </div>

    <!-- Video Player Container -->
    <div class="bg-slate-900 aspect-video rounded-[2.5rem] overflow-hidden shadow-2xl relative mb-6 group/player hw-accelerate">
        <div id="player-container" class="w-full h-full flex items-center justify-center">
            <div class="text-center p-10">
                <div class="w-20 h-20 bg-primary/20 text-primary rounded-full flex items-center justify-center mx-auto mb-6 shadow-2xl animate-pulse">
                    <i class="ph-fill ph-play text-4xl"></i>
                </div>
                <h3 class="text-white font-black text-2xl tracking-tighter">PuZero <span class="text-primary">Play</span></h3>
                <p class="text-slate-500 text-[10px] font-bold uppercase tracking-[0.3em] mt-3">Mempersiapkan Streaming...</p>
            </div>
        </div>
    </div>

    <!-- Navigation Buttons -->
    <div class="flex items-center justify-between gap-4 mb-10">
        <% if (stream.prevEps) { %>
            <button 
                hx-get="/anime/stream/<%= stream.prevEps %>"
                hx-target="#main-content"
                hx-push-url="true"
                class="flex-1 flex items-center justify-center gap-2 py-4 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm hw-accelerate"
            >
                <i class="ph-bold ph-caret-left"></i> Episode Sebelumnya
            </button>
        <% } else { %>
            <div class="flex-1"></div>
        <% } %>

        <% if (stream.nextEps) { %>
            <button 
                hx-get="/anime/stream/<%= stream.nextEps %>"
                hx-target="#main-content"
                hx-push-url="true"
                class="flex-1 flex items-center justify-center gap-2 py-4 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm hw-accelerate"
            >
                Episode Berikutnya <i class="ph-bold ph-caret-right"></i>
            </button>
        <% } else { %>
            <div class="flex-1"></div>
        <% } %>
    </div>

    <!-- Server Selector -->
    <div class="mb-12">
        <h3 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-4 flex items-center gap-2">
            <i class="ph-bold ph-hard-drives text-primary"></i> Pilih Server / Resolusi
        </h3>
        <div class="flex flex-wrap gap-2">
            <% stream.servers.forEach((srv, idx) => { %>
                <button 
                    onclick="changeServer(this)"
                    data-post="<%= srv.post %>"
                    data-nume="<%= srv.nume %>"
                    data-type="<%= srv.type %>"
                    class="server-btn px-5 py-3 bg-white border border-slate-200 rounded-2xl text-xs font-bold text-slate-600 hover:border-primary hover:text-primary transition-all shadow-sm hw-accelerate"
                >
                    <%= srv.name %>
                </button>
            <% }) %>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">
        <!-- Download Links -->
        <div class="lg:col-span-2 space-y-8 content-auto">
            <h3 class="text-xl font-black text-secondary flex items-center gap-2">
                <i class="ph-bold ph-download-simple text-primary"></i>
                Link Download
            </h3>

            <% stream.downloads.forEach(dl => { %>
                <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden hw-accelerate">
                    <div class="bg-slate-50 px-6 py-3 border-b border-slate-100">
                        <span class="text-xs font-black text-slate-400 uppercase tracking-widest"><%= dl.format %></span>
                    </div>
                    <div class="p-6 space-y-6">
                        <% dl.items.forEach(item => { %>
                            <div class="flex flex-col md:flex-row md:items-center gap-4 border-b border-slate-50 pb-4 last:border-0 last:pb-0">
                                <div class="w-20 shrink-0">
                                    <span class="px-3 py-1 bg-secondary text-white text-[10px] font-black rounded-lg"><%= item.resolution %></span>
                                </div>
                                <div class="flex flex-wrap gap-2">
                                    <% item.links.forEach(l => { %>
                                        <a href="<%= l.link %>" target="_blank" class="px-3 py-1.5 bg-slate-100 hover:bg-primary hover:text-white rounded-lg text-[10px] font-bold text-slate-600 transition-all">
                                            <%= l.server %>
                                        </a>
                                    <% }) %>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% }) %>
        </div>

        <!-- Episodes List -->
        <div class="space-y-6 content-auto">
            <h3 class="text-xl font-black text-secondary flex items-center gap-2">
                <i class="ph-bold ph-squares-four text-primary"></i>
                Episode Lainnya
            </h3>
            <div class="space-y-3">
                <% stream.episodes.forEach(ep => { %>
                    <a 
                        hx-get="/anime/stream/<%= ep.slug %>"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="flex items-center gap-4 p-3 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 transition-all group cursor-pointer hw-accelerate"
                    >
                        <div class="w-16 h-10 shrink-0 rounded-lg overflow-hidden bg-slate-100">
                            <img src="<%= ep.thumb %>" loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-110 transition-transform">
                        </div>
                        <div class="overflow-hidden">
                            <h4 class="text-xs font-bold text-slate-700 truncate group-hover:text-primary transition-colors"><%= ep.title %></h4>
                            <p class="text-[10px] text-slate-400 mt-0.5"><%= ep.date %></p>
                        </div>
                    </a>
                <% }) %>
            </div>
        </div>
    </div>
</div>

<script>
    // Logic for History
    (function saveToHistory() {
        const historyData = {
            title: document.getElementById('stream-title').innerText,
            url: window.location.pathname,
            type: 'anime',
            thumb: '<%= (stream.episodes && stream.episodes.length > 0) ? stream.episodes[0].thumb : "" %>',
            timestamp: Date.now()
        };

        let history = JSON.parse(localStorage.getItem('puzero_history') || '[]');
        // Remove existing if same URL
        history = history.filter(item => item.url !== historyData.url);
        // Add to beginning
        history.unshift(historyData);
        // Keep only 20
        if (history.length > 20) history = history.slice(0, 20);
        
        localStorage.setItem('puzero_history', JSON.stringify(history));
    })();

    async function changeServer(btn) {
        const post = btn.getAttribute('data-post');
        const nume = btn.getAttribute('data-nume');
        const type = btn.getAttribute('data-type');
        const container = document.getElementById('player-container');

        document.querySelectorAll('.server-btn').forEach(b => {
            b.classList.remove('bg-primary', 'text-white', 'border-primary');
            b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
        });
        btn.classList.add('bg-primary', 'text-white', 'border-primary');
        btn.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');

        if (window.videojs && videojs.getPlayer('puzero-player')) {
            videojs.getPlayer('puzero-player').dispose();
        }

        container.innerHTML = `
            <div class="flex flex-col items-center justify-center gap-4 h-full w-full">
                <div class="w-10 h-10 border-4 border-primary/20 border-t-primary rounded-full animate-spin hw-accelerate"></div>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">PuZero Play Engine...</span>
            </div>
        `;

        try {
            const res = await fetch('/anime/player', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ post, nume, type })
            });

            const contentType = res.headers.get('content-type');
            if (contentType && contentType.includes('application/json')) {
                const data = await res.json();
                
                if (data.type === 'video') {
                    const vidType = data.content.includes('.m3u8') ? 'application/x-mpegURL' : 'video/mp4';
                    container.innerHTML = `
                        <video id="puzero-player" class="video-js vjs-default-skin vjs-big-play-centered w-full h-full" controls preload="auto" data-setup='{"fluid": true}'>
                            <source src="${data.content}" type="${vidType}">
                        </video>
                    `;
                    if (window.videojs) {
                        videojs('puzero-player');
                    }
                } else if (data.type === 'iframe') {
                    container.innerHTML = `<iframe src="${data.content}" class="w-full h-full" frameborder="0" allowfullscreen></iframe>`;
                } else if (data.type === 'html') {
                    container.innerHTML = data.content;
                } else {
                    container.innerHTML = `<div class="text-red-500 text-xs font-bold text-center">${data.content}</div>`;
                }
            } else {
                const html = await res.text();
                const match = html.match(/src="([^"]+)"/);
                if (match && match[1]) {
                    container.innerHTML = `<iframe src="${match[1]}" class="w-full h-full" frameborder="0" allowfullscreen></iframe>`;
                } else {
                    container.innerHTML = html; 
                }
            }
        } catch (e) {
            container.innerHTML = `<div class="text-red-500 text-xs font-bold text-center">Gagal memuat player. Silakan coba server lain.</div>`;
        }
    }

    (function autoSelectServer() {
        const serverButtons = document.querySelectorAll('.server-btn');
        if (serverButtons.length === 0) return;

        let target = null;
        for (const btn of serverButtons) {
            if (btn.innerText.includes('PuruZero')) {
                target = btn;
                break;
            }
        }

        if (!target) {
            for (const btn of serverButtons) {
                if (btn.innerText.includes('720p')) {
                    target = btn;
                    break;
                }
            }
        }

        if (!target) target = serverButtons[0];
        
        if (target) {
            changeServer(target);
        }
    })();
</script>