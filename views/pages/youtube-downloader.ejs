<title><%= title %></title>
<div class="max-w-3xl mx-auto py-10 md:py-16 px-4 sm:px-6 fade-in flex-grow">
    <div class="mb-6 md:mb-8">
        <button 
            hx-get="/category" 
            hx-target="#main-content" 
            hx-push-url="true"
            class="flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-primary transition-all group hw-accelerate"
        >
            <div class="w-8 h-8 flex items-center justify-center rounded-lg bg-white border border-slate-200 group-hover:border-primary/30 group-hover:bg-primary/5 shadow-sm transition-all">
                <i class="ph-bold ph-arrow-left"></i>
            </div>
            Kembali ke Kategori
        </button>
    </div>

    <div class="text-center mb-10 md:mb-12">
        <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-2xl md:rounded-3xl bg-red-600/10 text-red-600 mb-4 md:mb-6 shadow-inner relative hw-accelerate">
            <div class="absolute inset-0 bg-red-600/20 blur-xl rounded-full animate-pulse"></div>
            <i class="ph-bold ph-youtube-logo text-3xl md:text-4xl relative z-10"></i>
        </div>
        <h1 class="text-3xl md:text-4xl font-black text-secondary tracking-tight">YouTube Downloader</h1>
        <p class="text-slate-500 mt-2 md:mt-3 text-base md:text-lg">Unduh video YouTube dengan kualitas tinggi dengan mudah.</p>
    </div>

    <div class="bg-white p-1.5 md:p-2 rounded-[2rem] md:rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100 relative hw-accelerate">
        <div class="p-6 md:p-8">
            <div class="space-y-4 md:space-y-5">
                <div class="group">
                    <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">YouTube Video Link</label>
                    <div class="relative">
                        <i class="ph-bold ph-link absolute left-4 md:left-5 top-1/2 -translate-y-1/2 text-slate-400 text-lg md:text-xl group-focus-within:text-red-600 transition-colors"></i>
                        <input 
                            type="url" 
                            id="yt-url" 
                            placeholder="https://www.youtube.com/watch?v=..." 
                            class="w-full pl-12 md:pl-14 pr-4 md:pr-6 py-4 md:py-5 bg-slate-50 border-2 border-slate-100 rounded-xl md:rounded-2xl focus:bg-white focus:border-red-600 outline-none transition-all font-medium text-base md:text-sm"
                        >
                    </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div class="group">
                        <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Kualitas</label>
                        <select id="yt-quality" class="w-full px-4 md:px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-xl md:rounded-2xl focus:bg-white focus:border-red-600 outline-none transition-all font-bold text-base md:text-sm text-slate-700">
                            <option value="360">360p</option>
                            <option value="480" selected>480p</option>
                            <option value="720">720p</option>
                            <option value="1080">1080p</option>
                        </select>
                    </div>
                    <div class="group">
                        <label class="block text-sm font-bold text-slate-700 mb-2 ml-1">Tipe</label>
                        <select id="yt-type" class="w-full px-4 md:px-5 py-4 bg-slate-50 border-2 border-slate-100 rounded-xl md:rounded-2xl focus:bg-white focus:border-red-600 outline-none transition-all font-bold text-base md:text-sm text-slate-700">
                            <option value="video">Video (MP4)</option>
                            <option value="audio">Audio (MP3)</option>
                        </select>
                    </div>
                </div>

                <button onclick="downloadYoutube()" id="yt-btn" class="w-full py-4 md:py-5 bg-secondary hover:bg-slate-800 text-white font-black rounded-xl md:rounded-2xl flex items-center justify-center gap-2 md:gap-3 transition-all hover:shadow-lg active:scale-[0.98] btn-hover-effect text-base">
                    <i class="ph-bold ph-download-simple text-lg md:text-xl"></i>
                    Dapatkan Link Download
                </button>
            </div>

            <div id="loading" class="hidden mt-8 md:mt-10 text-center py-8 md:py-12">
                <div class="flex flex-col items-center justify-center space-y-4">
                    <div class="w-10 h-10 md:w-12 h-12 border-4 border-red-200 border-t-red-600 rounded-full animate-spin"></div>
                    <p class="text-xs md:text-sm font-bold text-slate-400 uppercase tracking-wider">Memproses Video...</p>
                </div>
            </div>

            <div id="result-container" class="mt-8"></div>
        </div>
    </div>
</div>

<script>
    async function downloadYoutube() {
        const url = document.getElementById('yt-url').value;
        const quality = document.getElementById('yt-quality').value;
        const type = document.getElementById('yt-type').value;
        const resultContainer = document.getElementById('result-container');
        const loading = document.getElementById('loading');
        const btn = document.getElementById('yt-btn');

        if (!url) return alert('Masukkan URL YouTube dulu!');

        resultContainer.innerHTML = '';
        loading.classList.remove('hidden');
        btn.disabled = true;

        try {
            const res = await fetch('https://www.puruboy.kozow.com/api/downloader/savetube', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ url, quality, type })
            });
            const data = await res.json();

            if (!data.success) throw new Error('Gagal mengambil data YouTube.');

            const result = data.result;
            resultContainer.innerHTML = `
                <div class="animation-fade-in space-y-6">
                    <div class="flex flex-col sm:flex-row gap-5 p-5 bg-slate-50 rounded-2xl md:rounded-[2rem] border border-slate-100 hw-accelerate">
                        <img src="${result.thumbnail}" loading="lazy" decoding="async" class="w-full sm:w-32 md:w-40 h-auto object-cover rounded-xl shadow-md shrink-0">
                        <div class="flex-grow space-y-2.5 flex flex-col justify-center">
                            <div>
                                <span class="px-2.5 py-1 bg-red-600 text-white text-[10px] font-black rounded-md uppercase tracking-widest shadow-sm">${result.type} • ${result.quality}p</span>
                            </div>
                            <h3 class="text-base md:text-lg font-black text-secondary leading-snug line-clamp-2">${result.title}</h3>
                            <div class="pt-2">
                                <a href="${result.downloadUrl}" target="_blank" class="w-full py-3.5 bg-primary hover:bg-indigo-600 text-white font-bold rounded-xl flex items-center justify-center gap-2 transition-all shadow-md active:scale-95 text-sm md:text-base">
                                    <i class="ph-bold ph-download-simple"></i>
                                    Download Sekarang
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        } catch (err) {
            resultContainer.innerHTML = `<div class="p-4 text-xs md:text-sm text-red-800 rounded-xl bg-red-50 border border-red-200 font-medium">❌ Error: ${err.message}</div>`;
        } finally {
            loading.classList.add('hidden');
            btn.disabled = false;
        }
    }
</script>
