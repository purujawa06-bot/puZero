<title><%= title %></title>
<div class="relative min-h-screen bg-slate-900 flex flex-col fade-in">
    <!-- Reader Header -->
    <div class="sticky top-0 z-50 bg-slate-900/80 backdrop-blur-md border-b border-white/10 px-4 py-4">
        <div class="max-w-7xl mx-auto flex items-center justify-between">
            <button 
                hx-get="<%= mangaUrl ? '/manga/detail?url=' + encodeURIComponent(mangaUrl) : '/manga' %>" 
                hx-target="#main-content" 
                hx-push-url="true" 
                class="p-2 text-white/70 hover:text-primary transition-colors"
                title="Kembali"
            >
                <i class="fas fa-arrow-left text-xl"></i>
            </button>
            
            <div class="text-center overflow-hidden px-4">
                <h1 class="text-white font-bold text-sm md:text-base truncate" id="manga-title"><%= result.title %></h1>
            </div>

            <div class="flex items-center gap-2">
                <button hx-get="/manga" hx-target="#main-content" hx-push-url="true" class="p-2 text-white/70 hover:text-primary transition-colors">
                    <i class="fas fa-home text-xl"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Images Container -->
    <div class="flex-grow flex flex-col items-center bg-black">
        <div class="w-full max-w-3xl flex flex-col">
            <% result.images.forEach(img => { %>
                <div class="relative w-full">
                    <img 
                        src="<%= img.url %>" 
                        alt="<%= img.alt %>" 
                        loading="lazy" 
                        decoding="async"
                        class="w-full h-auto block select-none pointer-events-none"
                        onerror="this.src='/favicon.jpg'; this.classList.add('opacity-20');"
                    >
                    <div class="absolute inset-0 -z-10 bg-slate-800 animate-pulse"></div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Navigation Footer -->
    <div class="sticky bottom-6 mx-auto z-50 flex flex-col items-center gap-4 w-full px-4">
        <div class="flex items-center gap-3 bg-slate-900/90 backdrop-blur-xl border border-white/10 p-2 rounded-2xl shadow-2xl">
            <% if (prevUrl) { %>
                <button 
                    hx-get="/manga/read?url=<%= encodeURIComponent(prevUrl) %>&mangaUrl=<%= encodeURIComponent(mangaUrl) %>" 
                    hx-target="#main-content" 
                    hx-push-url="true"
                    class="flex items-center justify-center w-12 h-12 rounded-xl bg-white/5 text-white hover:bg-primary transition-all"
                    title="Chapter Sebelumnya"
                >
                    <i class="fas fa-chevron-left text-xl"></i>
                </button>
            <% } else { %>
                <div class="w-12 h-12 rounded-xl bg-white/5 text-white/20 flex items-center justify-center cursor-not-allowed">
                    <i class="fas fa-chevron-left text-xl"></i>
                </div>
            <% } %>

            <button 
                hx-get="<%= mangaUrl ? '/manga/detail?url=' + encodeURIComponent(mangaUrl) : '/manga' %>" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="px-6 py-3 bg-primary text-white rounded-xl font-black text-xs uppercase tracking-widest hover:scale-105 active:scale-95 transition-all shadow-lg shadow-primary/20"
            >
                Selesai Membaca
            </button>

            <% if (nextUrl) { %>
                <button 
                    hx-get="/manga/read?url=<%= encodeURIComponent(nextUrl) %>&mangaUrl=<%= encodeURIComponent(mangaUrl) %>" 
                    hx-target="#main-content" 
                    hx-push-url="true"
                    class="flex items-center justify-center w-12 h-12 rounded-xl bg-white/5 text-white hover:bg-primary transition-all"
                    title="Chapter Selanjutnya"
                >
                    <i class="fas fa-chevron-right text-xl"></i>
                </button>
            <% } else { %>
                <div class="w-12 h-12 rounded-xl bg-white/5 text-white/20 flex items-center justify-center cursor-not-allowed">
                    <i class="fas fa-chevron-right text-xl"></i>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    (function saveToHistory() {
        const historyData = {
            title: document.getElementById('manga-title').innerText,
            url: window.location.pathname + window.location.search,
            type: 'manga',
            thumb: '/favicon.jpg',
            timestamp: Date.now()
        };

        let history = JSON.parse(localStorage.getItem('puzero_history') || '[]');
        
        // Mencegah duplikasi: hapus entri lama dengan URL yang sama
        history = history.filter(item => item.url !== historyData.url);
        
        // Tambahkan ke urutan paling atas
        history.unshift(historyData);
        
        // Batasi maksimal 20 item
        if (history.length > 20) history = history.slice(0, 20);
        
        localStorage.setItem('puzero_history', JSON.stringify(history));
    })();
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.1);
        border-radius: 10px;
    }
</style>