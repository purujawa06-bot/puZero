<title><%= title %></title>
<div class="relative overflow-hidden flex-grow fade-in pb-16" x-data="{ showFilters: false }">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 md:pt-16">
        <div class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div class="text-center md:text-left">
                <h1 class="text-3xl sm:text-4xl font-extrabold text-secondary tracking-tight mb-2">
                    Database <span class="text-primary">Anime</span>
                </h1>
                <p class="text-slate-500 text-sm font-medium">Filter ribuan judul anime berdasarkan preferensi Anda.</p>
            </div>

            <div class="flex items-center gap-2">
                <button 
                    @click="showFilters = !showFilters" 
                    class="px-6 py-3.5 bg-white border border-slate-200 rounded-2xl text-slate-600 font-bold hover:border-primary hover:text-primary transition-all shadow-sm flex items-center gap-2 active:scale-95"
                >
                    <i class="ph-bold ph-funnel"></i> 
                    <span x-text="showFilters ? 'Tutup Filter' : 'Filter & Genre'"></span>
                </button>
            </div>
        </div>

        <!-- Filter Form -->
        <div 
            x-show="showFilters" 
            x-transition:enter="transition ease-out duration-300"
            x-transition:enter-start="opacity-0 -translate-y-4"
            x-transition:enter-end="opacity-100 translate-y-0"
            class="mb-10 bg-white p-6 md:p-8 rounded-[2rem] border border-slate-100 shadow-xl shadow-slate-200/50"
        >
            <form 
                hx-get="/anime/filter" 
                hx-target="#main-content" 
                hx-push-url="true"
                class="space-y-8"
            >
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Cari Judul</label>
                        <input type="text" name="title" value="<%= filters.title || '' %>" placeholder="Ketik nama anime..." class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:outline-none focus:border-primary transition-colors text-sm font-bold">
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Status</label>
                        <select name="status" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:outline-none focus:border-primary transition-colors text-sm font-bold">
                            <option value="">Semua</option>
                            <option value="Currently Airing" <%= filters.status === 'Currently Airing' ? 'selected' : '' %>>Currently Airing</option>
                            <option value="Finished Airing" <%= filters.status === 'Finished Airing' ? 'selected' : '' %>>Finished Airing</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Tipe</label>
                        <select name="type" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:outline-none focus:border-primary transition-colors text-sm font-bold">
                            <option value="">Semua</option>
                            <option value="TV" <%= filters.type === 'TV' ? 'selected' : '' %>>TV</option>
                            <option value="Movie" <%= filters.type === 'Movie' ? 'selected' : '' %>>Movie</option>
                            <option value="OVA" <%= filters.type === 'OVA' ? 'selected' : '' %>>OVA</option>
                            <option value="ONA" <%= filters.type === 'ONA' ? 'selected' : '' %>>ONA</option>
                            <option value="Special" <%= filters.type === 'Special' ? 'selected' : '' %>>Special</option>
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Urutan</label>
                        <select name="order" class="w-full px-4 py-3 bg-slate-50 border border-slate-100 rounded-xl focus:outline-none focus:border-primary transition-colors text-sm font-bold">
                            <option value="title" <%= filters.order === 'title' ? 'selected' : '' %>>A-Z</option>
                            <option value="titlereverse" <%= filters.order === 'titlereverse' ? 'selected' : '' %>>Z-A</option>
                            <option value="update" <%= filters.order === 'update' ? 'selected' : '' %>>Update Terbaru</option>
                            <option value="latest" <%= filters.order === 'latest' ? 'selected' : '' %>>Baru Ditambahkan</option>
                            <option value="popular" <%= filters.order === 'popular' ? 'selected' : '' %>>Populer</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-3">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest ml-1">Genre Pilihan</label>
                    <div class="flex flex-wrap gap-2">
                        <% const genreList = [
                            {id: 'fantasy', name: 'Fantasy'}, {id: 'action', name: 'Action'}, {id: 'adventure', name: 'Adventure'}, 
                            {id: 'comedy', name: 'Comedy'}, {id: 'shounen', name: 'Shounen'}, {id: 'school', name: 'School'}, 
                            {id: 'romance', name: 'Romance'}, {id: 'drama', name: 'Drama'}, {id: 'supernatural', name: 'Supernatural'}, 
                            {id: 'isekai', name: 'Isekai'}, {id: 'sci-fi', name: 'Sci-Fi'}, {id: 'seinen', name: 'Seinen'}, 
                            {id: 'reincarnation', name: 'Reincarnation'}, {id: 'super-power', name: 'Super Power'}, 
                            {id: 'historical', name: 'Historical'}, {id: 'mystery', name: 'Mystery'}, {id: 'harem', name: 'Harem'}, 
                            {id: 'ecchi', name: 'Ecchi'}, {id: 'slice-of-life', name: 'Slice of Life'}, {id: 'sports', name: 'Sports'}
                        ]; %>
                        <% genreList.forEach(g => { %>
                            <label class="cursor-pointer">
                                <input type="checkbox" name="genre" value="<%= g.id %>" class="hidden peer" <%= filters.genre.includes(g.id) ? 'checked' : '' %>>
                                <span class="px-4 py-2 bg-slate-50 border border-slate-100 rounded-xl text-xs font-bold text-slate-500 peer-checked:bg-primary peer-checked:text-white peer-checked:border-primary transition-all block">
                                    <%= g.name %>
                                </span>
                            </label>
                        <% }) %>
                    </div>
                </div>

                <div class="pt-4 flex justify-end">
                    <button type="submit" class="w-full md:w-auto px-10 py-4 bg-secondary text-white rounded-2xl font-black shadow-lg hover:bg-slate-800 transition-all active:scale-95">
                        Terapkan Filter
                    </button>
                </div>
            </form>
        </div>

        <!-- Result Grid -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4 md:gap-6">
            <% if (animeList && animeList.length > 0) { %>
                <% animeList.forEach(anime => { %>
                    <div 
                        hx-get="/anime/detail/<%= anime.slug %>"
                        hx-target="#main-content"
                        hx-push-url="true"
                        class="group bg-white rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl hover:border-primary/20 transition-all duration-300 cursor-pointer flex flex-col"
                    >
                        <div class="relative aspect-[3/4] overflow-hidden bg-slate-100">
                            <img src="<%= anime.thumb %>" alt="<%= anime.title %>" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700">
                            <div class="absolute top-2.5 left-2.5">
                                <span class="px-2.5 py-1 bg-primary text-white text-[9px] font-black rounded-lg shadow-md uppercase">
                                    <%= anime.ep %>
                                </span>
                            </div>
                        </div>
                        <div class="p-4 flex flex-col flex-grow">
                            <h3 class="text-xs font-bold text-secondary line-clamp-2 mb-2 group-hover:text-primary transition-colors flex-grow">
                                <%= anime.title %>
                            </h3>
                            <div class="mt-auto pt-2 border-t border-slate-50">
                                <span class="text-[9px] text-slate-400 font-bold uppercase tracking-widest line-clamp-1"><%= anime.uploaded %></span>
                            </div>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full py-20 text-center">
                    <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center mx-auto mb-4 text-slate-300">
                        <i class="ph-bold ph-magnifying-glass text-3xl"></i>
                    </div>
                    <p class="text-slate-400 font-bold text-sm">Tidak ada anime yang sesuai filter.</p>
                </div>
            <% } %>
        </div>

        <!-- Pagination -->
        <% if (pagination && pagination.length > 1) { %>
            <div class="mt-12 flex flex-wrap justify-center gap-2">
                <% pagination.forEach(p => { %>
                    <% if (p.pageNum) { %>
                        <button 
                            hx-get="/anime/filter?<%= new URLSearchParams({...filters, page: p.pageNum}).toString().replace(/genre=/g, 'genre[]=') %>"
                            hx-target="#main-content"
                            hx-push-url="true"
                            class="w-10 h-10 flex items-center justify-center rounded-xl font-bold text-sm transition-all <%= p.isCurrent ? 'bg-primary text-white shadow-lg shadow-primary/20' : 'bg-white border border-slate-200 text-slate-500 hover:border-primary hover:text-primary' %>"
                        >
                            <%= p.text %>
                        </button>
                    <% } else { %>
                        <span class="w-10 h-10 flex items-center justify-center text-slate-300 font-bold"><%= p.text %></span>
                    <% } %>
                <% }) %>
            </div>
        <% } %>
    </div>
</div>
