<title><%= title %></title>
<div class="relative flex-grow flex flex-col overflow-hidden">
    <!-- Background Orbs -->
    <div class="pointer-events-none -z-10 overflow-hidden absolute inset-0">
        <div class="absolute -top-24 -left-16 w-[50vw] h-[50vw] max-w-[500px] max-h-[500px] bg-primary/15 rounded-full blur-[100px] opacity-70"></div>
        <div class="absolute -bottom-16 -right-16 w-[45vw] h-[45vw] max-w-[450px] max-h-[450px] bg-accent/10 rounded-full blur-[90px] opacity-70"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[30vw] h-[30vw] max-w-[300px] max-h-[300px] bg-indigo-400/8 rounded-full blur-[80px]"></div>
    </div>

    <div class="max-w-4xl mx-auto w-full px-4 sm:px-6 py-10 sm:py-16 md:py-24 flex flex-col items-center text-center flex-grow justify-center">
        <!-- Logo -->
        <div class="relative group mb-6 sm:mb-8 fade-in" style="animation-delay:0s">
            <div class="absolute -inset-2 bg-gradient-to-r from-primary to-accent rounded-[2.5rem] blur-lg opacity-25 group-hover:opacity-50 transition duration-700"></div>
            <div class="relative w-20 h-20 sm:w-24 sm:h-24 md:w-28 md:h-28 rounded-[1.75rem] bg-gradient-to-tr from-primary via-indigo-500 to-accent flex items-center justify-center shadow-2xl shadow-primary/25 group-hover:scale-105 transition-transform duration-500">
                <i class="ph-bold ph-lightning text-white text-3xl sm:text-4xl md:text-5xl"></i>
            </div>
        </div>

        <!-- Badge -->
        <div class="fade-in mb-5 sm:mb-6" style="animation-delay:0.05s">
            <span class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-white/80 dark:bg-slate-800/80 backdrop-blur-sm border border-slate-200/60 dark:border-slate-700/60 text-slate-600 dark:text-slate-300 text-xs font-bold shadow-sm">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                </span>
                All-in-One AI Productivity Hub
            </span>
        </div>

        <!-- Headline -->
        <h1 class="fade-in text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-black text-secondary dark:text-white tracking-tight mb-4 sm:mb-5 leading-[1.1]" style="animation-delay:0.1s">
            Optimalkan Pekerjaan
            <br>
            Dengan <span class="gradient-text">PuZero AI.</span>
        </h1>

        <!-- Subtitle -->
        <p class="fade-in max-w-xl mx-auto text-sm sm:text-base md:text-lg text-slate-500 dark:text-slate-400 mb-8 sm:mb-10 leading-relaxed px-2" style="animation-delay:0.15s">
            Platform serba guna untuk mengunduh media, mengolah data, dan meningkatkan produktivitas menggunakan teknologi AI terbaru.
        </p>

        <!-- CTA Buttons -->
        <div class="fade-in flex flex-col sm:flex-row items-stretch sm:items-center justify-center gap-3 w-full max-w-sm sm:max-w-none mb-12 sm:mb-16 md:mb-20 px-4 sm:px-0" style="animation-delay:0.2s">
            <a hx-get="/category" hx-target="#main-content" hx-push-url="true"
               class="cursor-pointer px-7 py-3.5 sm:py-4 bg-secondary dark:bg-primary text-white rounded-2xl font-black text-sm sm:text-base hover:bg-slate-700 dark:hover:opacity-90 transition-all shadow-lg shadow-slate-900/15 flex items-center justify-center gap-2.5 active:scale-95 group btn-hover-effect">
                Mulai Sekarang
                <i class="ph-bold ph-arrow-right group-hover:translate-x-1 transition-transform"></i>
            </a>
            <a hx-get="/features" hx-target="#main-content" hx-push-url="true"
               class="cursor-pointer px-7 py-3.5 sm:py-4 bg-white dark:bg-slate-800 border-2 border-slate-100 dark:border-slate-700 text-slate-600 dark:text-slate-300 rounded-2xl font-bold text-sm sm:text-base hover:border-primary/40 hover:text-primary transition-all active:scale-95 flex items-center justify-center">
                Pelajari Fitur
            </a>
        </div>

        <!-- Stats / Feature Pills -->
        <div class="fade-in grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 w-full max-w-2xl mx-auto stagger" style="animation-delay:0.25s">
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 rounded-2xl p-4 sm:p-5 border border-slate-100 dark:border-slate-700/50 shadow-sm flex flex-col items-center gap-2.5">
                <div class="w-11 h-11 rounded-xl bg-amber-50 dark:bg-amber-500/10 flex items-center justify-center cat-icon">
                    <i class="ph-bold ph-lightning text-xl text-amber-500"></i>
                </div>
                <div class="text-center">
                    <div class="font-black text-secondary dark:text-white text-sm">Fast Speed</div>
                    <div class="text-[10px] text-slate-400 font-medium">Ultra cepat</div>
                </div>
            </div>
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 rounded-2xl p-4 sm:p-5 border border-slate-100 dark:border-slate-700/50 shadow-sm flex flex-col items-center gap-2.5">
                <div class="w-11 h-11 rounded-xl bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center cat-icon">
                    <i class="ph-bold ph-shield-check text-xl text-emerald-500"></i>
                </div>
                <div class="text-center">
                    <div class="font-black text-secondary dark:text-white text-sm">Secure</div>
                    <div class="text-[10px] text-slate-400 font-medium">Aman & privat</div>
                </div>
            </div>
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 rounded-2xl p-4 sm:p-5 border border-slate-100 dark:border-slate-700/50 shadow-sm flex flex-col items-center gap-2.5">
                <div class="w-11 h-11 rounded-xl bg-blue-50 dark:bg-blue-500/10 flex items-center justify-center cat-icon">
                    <i class="ph-bold ph-infinity text-xl text-blue-500"></i>
                </div>
                <div class="text-center">
                    <div class="font-black text-secondary dark:text-white text-sm">Unlimited</div>
                    <div class="text-[10px] text-slate-400 font-medium">Tanpa batas</div>
                </div>
            </div>
            <div class="animate-slide-up feature-card bg-white dark:bg-slate-800/60 rounded-2xl p-4 sm:p-5 border border-slate-100 dark:border-slate-700/50 shadow-sm flex flex-col items-center gap-2.5">
                <div class="w-11 h-11 rounded-xl bg-primary/8 dark:bg-primary/15 flex items-center justify-center cat-icon">
                    <i class="ph-bold ph-currency-circle-dollar text-xl text-primary"></i>
                </div>
                <div class="text-center">
                    <div class="font-black text-secondary dark:text-white text-sm">100% Free</div>
                    <div class="text-[10px] text-slate-400 font-medium">Gratis selamanya</div>
                </div>
            </div>
        </div>
    </div>
</div>
